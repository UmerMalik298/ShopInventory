
@page "/billing/{Id:guid}"
@using ShopInventory.Domain.Entities.Enums
@using ShopInventory.Domain.Entities.Sales
@using ShopInventory.Domain.Entities.Billing
@using ShopInventory.Application.Interfaces
@inject IBillService BillService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ShopInventory.App.Services.BillPdfService BillPdfService

<div class="bill-detail-page" id="bill-detail-page">

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
        </div>
    }
    else if (bill == null)
    {
        <div class="not-found">
            <p>Bill not found.</p>
            <button @onclick="GoBack">Go back</button>
        </div>
    }
    else
    {
        <!-- Top Bar -->
        <div class="top-bar no-print">
            <button class="btn-back" @onclick="GoBack">&#8592; All Bills</button>
            <div class="top-actions">

                <select class="status-select @GetStatusSelectClass(bill.PaymentStatus)"
                        @bind="bill.PaymentStatus"
                        @bind:after="SaveStatus">
                    <option value="@PaymentStatus.Unpaid">Unpaid</option>
                    <option value="@PaymentStatus.Paid">Paid</option>
                    <option value="@PaymentStatus.PartiallyPaid">Partially Paid</option>
                </select>

                <!-- Edit -->
                <button class="btn-action btn-edit" @onclick="EditBill" title="Edit Bill">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                    </svg>
                    <span>Edit</span>
                </button>

                <!-- Print -->
                <button class="btn-action btn-print" @onclick="PrintBill" title="Print">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 6 2 18 2 18 9" />
                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                        <rect x="6" y="14" width="12" height="8" />
                    </svg>
                    <span>Print</span>
                </button>

                <!-- WhatsApp -->
                <button class="btn-action btn-share" @onclick="ShareWhatsAppText" title="Share via WhatsApp">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                    </svg>
                    <span>WhatsApp</span>
                </button>

                <!-- Save PDF -->
                <button class="btn-action btn-download" @onclick="DownloadBill" title="Download">
                    <svg class="dl-arrow" width="17" height="17" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 3v13" />
                        <polyline points="7 13 12 18 17 13" />
                        <path d="M3 21h18" />
                    </svg>
                    <span>Save PDF</span>
                </button>

                <!-- Deduct Stock — shows badge if already deducted -->
                @if (bill.InventoryDeducted)
                {
                    <span class="stock-deducted-badge">&#10003; Stock Deducted</span>
                }
                else
                {
                    <button class="btn-action btn-deduct" @onclick="AskDeductInventory"
                            disabled="@isDeducting" title="Deduct from inventory">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 12V22H4V12" />
                            <path d="M22 7H2v5h20V7z" />
                            <path d="M12 22V7" />
                        </svg>
                        <span>@(isDeducting ? "Deducting..." : "Deduct Stock")</span>
                    </button>
                }

            </div>
        </div>

        <!-- Bill Receipt -->
        <div class="receipt-wrap" id="printArea">
            <div class="receipt">

                <div class="receipt-header">
                    <div class="shop-name">Sheer Rabbani Autos</div>
                    <div class="shop-sub">Receipt / Invoice</div>
                </div>

                <div class="receipt-meta">
                    <div class="meta-row">
                        <span class="meta-label">Bill No.</span>
                        <span class="meta-value mono">@bill.BillNo</span>
                    </div>
                    <div class="meta-row">
                        <span class="meta-label">Date</span>
                        <span class="meta-value">@bill.BilledAt.ToString("dd MMM yyyy, hh:mm tt")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(bill.CustomerName))
                    {
                        <div class="meta-row">
                            <span class="meta-label">Customer</span>
                            <span class="meta-value">@bill.CustomerName</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(bill.CustomerPhone))
                    {
                        <div class="meta-row">
                            <span class="meta-label">Phone</span>
                            <span class="meta-value">@bill.CustomerPhone</span>
                        </div>
                    }
                </div>

                <div class="items-section">
                    <div class="items-header">
                        <span>Item</span>
                        <span>Qty</span>
                        <span>Price</span>
                        <span>Total</span>
                    </div>
                    @foreach (var item in bill.Items)
                    {
                        <div class="item-row">
                            <span class="item-name-col">
                                @item.ProductName
                                @if (!string.IsNullOrEmpty(item.VariantName))
                                {
                                    <span class="variant-small">(@item.VariantName)</span>
                                }
                            </span>
                            <span>@item.Quantity</span>
                            <span>@item.UnitPrice.ToString("N0")</span>
                            <span class="item-total">@item.TotalPrice.ToString("N0")</span>
                        </div>
                    }
                </div>

                <div class="totals-section">
                    <div class="total-row">
                        <span>Subtotal</span>
                        <span>Rs. @bill.SubTotal.ToString("N0")</span>
                    </div>
                    @if (bill.DiscountAmount > 0)
                    {
                        <div class="total-row discount-row">
                            <span>Discount</span>
                            <span>− Rs. @bill.DiscountAmount.ToString("N0")</span>
                        </div>
                    }
                    <div class="total-row grand">
                        <span>Total</span>
                        <span>Rs. @bill.TotalAmount.ToString("N0")</span>
                    </div>
                </div>

                <div class="payment-info">
                    <div class="pay-row">
                        <span>Payment Method</span>
                        <span>@bill.PaymentMethod</span>
                    </div>
                    <div class="pay-row">
                        <span>Payment Status</span>
                        <span class="status-badge @GetStatusClass(bill.PaymentStatus)">
                            @bill.PaymentStatus
                        </span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(bill.Notes))
                {
                    <div class="receipt-notes">
                        <span class="notes-label">Notes:</span> @bill.Notes
                    </div>
                }

                <div class="receipt-footer">
                    <p>Thank you for your purchase!</p>
                </div>
            </div>
        </div>

        <!-- Deduct confirm dialog -->
        <ConfirmDialog IsOpen="showDeductConfirm"
                       Title="Deduct Stock"
                       Message="This will deduct all items in this bill from inventory. This can only be done once. Continue?"
                       ConfirmText="Yes, Deduct"
                       CancelText="Cancel"
                       IsDanger="false"
                       OnConfirm="ConfirmDeductInventory"
                       OnCancel="@(() => showDeductConfirm = false)" />

        <!-- Already deducted warning dialog -->
        <ConfirmDialog IsOpen="showAlreadyDeductedDialog"
                       Title="Already Deducted"
                       Message="Stock for this bill has already been deducted from inventory. It cannot be deducted again."
                       ConfirmText="OK"
                       CancelText=""
                       IsDanger="false"
                       OnConfirm="@(() => showAlreadyDeductedDialog = false)"
                       OnCancel="@(() => showAlreadyDeductedDialog = false)" />

        <!-- Deduct success dialog -->
        <ConfirmDialog IsOpen="showDeductSuccessDialog"
                       Title="Stock Deducted"
                       Message="Inventory has been updated successfully."
                       ConfirmText="OK"
                       CancelText=""
                       IsDanger="false"
                       OnConfirm="@(() => showDeductSuccessDialog = false)"
                       OnCancel="@(() => showDeductSuccessDialog = false)" />

        <!-- Deduct error dialog -->
        <ConfirmDialog IsOpen="showDeductErrorDialog"
                       Title="Deduction Failed"
                       Message="@deductErrorMessage"
                       ConfirmText="OK"
                       CancelText=""
                       IsDanger="true"
                       OnConfirm="@(() => showDeductErrorDialog = false)"
                       OnCancel="@(() => showDeductErrorDialog = false)" />
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private Bill? bill;
    private bool isLoading = true;
    private bool isDeducting = false;

    // Dialog states
    private bool showDeductConfirm = false;
    private bool showAlreadyDeductedDialog = false;
    private bool showDeductSuccessDialog = false;
    private bool showDeductErrorDialog = false;
    private string deductErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        bill = await BillService.GetBillByIdAsync(Id);
        isLoading = false;
    }

    private async Task SaveStatus()
    {
        if (bill != null)
            await BillService.UpdatePaymentStatusAsync(bill.Id, bill.PaymentStatus);
    }

    private void EditBill() => Navigation.NavigateTo($"/billing/edit/{Id}");

    // Called when user clicks "Deduct Stock" button
    private void AskDeductInventory()
    {
        if (bill == null) return;

        if (bill.InventoryDeducted)
        {
            // Already done — show warning instead of confirm
            showAlreadyDeductedDialog = true;
            return;
        }

        showDeductConfirm = true;
    }

    // Called when user confirms in the dialog
    private async Task ConfirmDeductInventory()
    {
        showDeductConfirm = false;
        if (bill == null) return;

        isDeducting = true;
        try
        {
            await BillService.DeductInventoryAsync(bill.Id);
            bill.InventoryDeducted = true; // update UI instantly without reload
            showDeductSuccessDialog = true;
        }
        catch (Exception ex)
        {
            deductErrorMessage = ex.Message;
            showDeductErrorDialog = true;
        }
        finally
        {
            isDeducting = false;
            StateHasChanged();
        }
    }
    private async Task PrintBill()
    {


         //await JS.InvokeVoidAsync("window.print");



        if (bill == null) return;
        try
        {
            var pdfBytes = BillPdfService.GeneratePdf(bill);
            var tempPath = Path.Combine(Path.GetTempPath(), $"bill_{bill.BillNo}.pdf");
            await File.WriteAllBytesAsync(tempPath, pdfBytes);

            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
            {
                FileName = tempPath,
                UseShellExecute = true
            });
        }
        catch (Exception ex)
        {
            deductErrorMessage = ex.Message;
            showDeductErrorDialog = true;
        }
    }

    private bool isSharing = false;

    private async Task DownloadBill()
    {
        if (bill == null) return;
        try
        {
            var pdfBytes = BillPdfService.GeneratePdf(bill);
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("downloadPdfFile", $"{bill.BillNo}.pdf", base64);
        }
        catch (Exception ex)
        {
            deductErrorMessage = ex.Message;
            showDeductErrorDialog = true;
        }
    }

    private async Task ShareWhatsAppText()
    {
        if (bill == null) return;
        try
        {
            var text = BuildReceiptText();
            var encoded = Uri.EscapeDataString(text);
            var phone = "";
            if (!string.IsNullOrWhiteSpace(bill.CustomerPhone))
            {
                phone = bill.CustomerPhone
                    .Replace(" ", "").Replace("-", "")
                    .Replace("(", "").Replace(")", "").Replace("+", "");
                if (phone.StartsWith("0"))
                    phone = "92" + phone[1..];
            }
            var url = string.IsNullOrEmpty(phone)
                ? $"https://wa.me/?text={encoded}"
                : $"https://wa.me/{phone}?text={encoded}";

            await Launcher.Default.OpenAsync(new Uri(url));
        }
        catch (Exception ex)
        {
            deductErrorMessage = ex.Message;
            showDeductErrorDialog = true;
        }
    }

    private string BuildReceiptText()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("========================================");
        sb.AppendLine("           SHEER RABBANI AUTOS");
        sb.AppendLine("              RECEIPT");
        sb.AppendLine("========================================");
        sb.AppendLine($"Bill No : {bill!.BillNo}");
        sb.AppendLine($"Date    : {bill.BilledAt:dd MMM yyyy, hh:mm tt}");
        if (!string.IsNullOrEmpty(bill.CustomerName))
            sb.AppendLine($"Customer: {bill.CustomerName}");
        if (!string.IsNullOrEmpty(bill.CustomerPhone))
            sb.AppendLine($"Phone   : {bill.CustomerPhone}");
        sb.AppendLine("----------------------------------------");
        sb.AppendLine($"{"Item",-22} {"Qty",4} {"Price",8} {"Total",8}");
        sb.AppendLine("----------------------------------------");
        foreach (var item in bill.Items)
        {
            var name = string.IsNullOrEmpty(item.VariantName)
                ? item.ProductName
                : $"{item.ProductName} ({item.VariantName})";
            if (name.Length > 22) name = name[..22];
            sb.AppendLine($"{name,-22} {item.Quantity,4} {item.UnitPrice,8:N0} {item.TotalPrice,8:N0}");
        }
        sb.AppendLine("----------------------------------------");
        sb.AppendLine($"{"Subtotal",-30} {"Rs. " + bill.SubTotal.ToString("N0"),10}");
        if (bill.DiscountAmount > 0)
            sb.AppendLine($"{"Discount",-30} {"-Rs. " + bill.DiscountAmount.ToString("N0"),10}");
        sb.AppendLine($"{"TOTAL",-30} {"Rs. " + bill.TotalAmount.ToString("N0"),10}");
        sb.AppendLine("========================================");
        sb.AppendLine($"Payment : {bill.PaymentMethod}");
        sb.AppendLine($"Status  : {bill.PaymentStatus}");
        if (!string.IsNullOrEmpty(bill.Notes))
            sb.AppendLine($"Notes   : {bill.Notes}");
        sb.AppendLine("========================================");
        sb.AppendLine("      Thank you for your purchase!");
        sb.AppendLine("========================================");
        return sb.ToString();
    }

    private string GetStatusClass(PaymentStatus status) => status switch
    {
        PaymentStatus.Paid => "badge-paid",
        PaymentStatus.Unpaid => "badge-unpaid",
        PaymentStatus.PartiallyPaid => "badge-partial",
        _ => ""
    };

    private string GetStatusSelectClass(PaymentStatus status) => status switch
    {
        PaymentStatus.Paid => "select-paid",
        PaymentStatus.Unpaid => "select-unpaid",
        PaymentStatus.PartiallyPaid => "select-partial",
        _ => ""
    };

    private void GoBack() => Navigation.NavigateTo("/billing");
}





