<div class="bill-card">
    <h4 class="bill-card-title">Customer Details</h4>

    <div class="bill-form-grid">
        <div>
            <label>Name</label>
            <input class="form-control" value="@CustomerName" @oninput="e => OnCustomerNameChanged.InvokeAsync(e.Value?.ToString() ??" ")" />
        </div>

        <div>
            <label>Phone</label>
            <input class="form-control" value="@CustomerPhone" @oninput="e => OnCustomerPhoneChanged.InvokeAsync(e.Value?.ToString() ??" ")" />
        </div>

        <div class="full-width">
            <label>Address</label>
            <input class="form-control" value="@CustomerAddress" @oninput="e => OnCustomerAddressChanged.InvokeAsync(e.Value?.ToString() ??" ")" />
        </div>

        <div>
            <label>Payment Status</label>
            <select class="form-control" value="@PaymentStatus" @onchange="HandlePaymentStatusChanged">
                <option value="0">Unpaid</option>
                <option value="1">Paid</option>
            </select>
        </div>

        <div class="full-width">
            <label>Notes</label>
            <input class="form-control" value="@Notes" @oninput="e => OnNotesChanged.InvokeAsync(e.Value?.ToString() ??" ")" />
        </div>
    </div>
</div>

@code {
    [Parameter] public string CustomerName { get; set; } = "";
    [Parameter] public string CustomerPhone { get; set; } = "";
    [Parameter] public string CustomerAddress { get; set; } = "";
    [Parameter] public string Notes { get; set; } = "";
    [Parameter] public int PaymentStatus { get; set; }

    [Parameter] public EventCallback<string> OnCustomerNameChanged { get; set; }
    [Parameter] public EventCallback<string> OnCustomerPhoneChanged { get; set; }
    [Parameter] public EventCallback<string> OnCustomerAddressChanged { get; set; }
    [Parameter] public EventCallback<string> OnNotesChanged { get; set; }
    [Parameter] public EventCallback<int> OnPaymentStatusChanged { get; set; }

    private async Task HandlePaymentStatusChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
            await OnPaymentStatusChanged.InvokeAsync(value);
    }
}