@page "/billing/create"
@using ShopInventory.Domain.Entities.Sales
@using ShopInventory.Domain.Entities.Enums
@using ShopInventory.Domain.Entities.Billing
@using ShopInventory.Domain.Entities.Products
@using ShopInventory.Application.DTOs
@using ShopInventory.Application.Interfaces
@inject IBillService BillService
@inject IProductService ProductService
@inject NavigationManager Navigation
@inject ShopInventory.Infrastructure.Services.CartService CartService
<div class="create-bill-page">

    <!-- Top Bar -->
    <div class="top-bar">
        <button class="btn-back" @onclick="GoBack">&#8592; Back</button>
        <h2>New Bill</h2>
        <div class="top-actions">
            <button class="btn-outline" @onclick="SaveDraft" disabled="@isSaving">Save Draft</button>
            <button class="btn-primary" @onclick="SaveBill" disabled="@(billItems.Count == 0 || isSaving)">
                @(isSaving ? "Saving..." : "Save Bill")
            </button>
        </div>
    </div>

    <div class="bill-layout">

        <!-- LEFT: Customer + Items -->
        <div class="left-col">

            <!-- Customer Info -->
            <div class="section-card">
                <div class="section-title">Customer Info</div>
                <div class="form-row">
                    <div class="form-field">
                        <label>Customer Name</label>
                        <input type="text" placeholder="Walk-in customer" @bind="customerName" />
                    </div>
                    <div class="form-field" style="max-width:180px">
                        <label>Phone Number</label>
                        <input type="text" placeholder="+92 300 0000000" @bind="customerPhone" />
                    </div>
                </div>
                <div class="form-field">
                    <label>Notes (optional)</label>
                    <input type="text" placeholder="Any notes for this bill..." @bind="notes" />
                </div>
            </div>

            <!-- Add Items -->
            <div class="section-card">
                <div class="section-title-row">
                    <span class="section-title">Add Products</span>
                    <button class="btn-toggle-manual" @onclick="ToggleManualEntry">
                        @(showManualEntry ? "✕ Close Manual Entry" : "＋ Manual Item")
                    </button>
                </div>

                <!-- Product Search (always visible) -->
                <div class="search-area">
                    <div class="search-wrap">
                        <input type="text"
                               placeholder="Search product by name or SKU..."
                               value="@productSearch"
                               @oninput="SearchProducts"
                               @onfocus="@(() => showDropdown = true)"
                               @onblur="HideDropdown" />

                        @if (showDropdown && searchResults.Count > 0)
                        {
                            <div class="dropdown">
                                @foreach (var product in searchResults)
                                {
                                    @if (product.HasVariants)
                                    {
                                        @foreach (var variant in product.Variants)
                                        {
                                            var p = product;
                                            var v = variant;
                                            <div class="dropdown-item @(v.Quantity == 0 ? "out-of-stock-item" : "")"
                                                 @onmousedown="@(() => TryAddItemFromVariant(p, v))">
                                                <div class="item-name">
                                                    @product.Name <span class="variant-tag">@variant.Name</span>
                                                    @if (v.Quantity == 0)
                                                    {
                                                        <span class="oos-badge">Out of Stock</span>
                                                    }
                                                </div>
                                                <div class="item-meta">
                                                    <span>Rs. @variant.SalePrice.ToString("N0")</span>
                                                    <span class="stock @(variant.Quantity == 0 ? "oos" : variant.Quantity < 5 ? "low" : "")">
                                                        Stock: @variant.Quantity
                                                    </span>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        var p = product;
                                        <div class="dropdown-item @(p.Quantity == 0 ? "out-of-stock-item" : "")"
                                             @onmousedown="@(() => TryAddItem(p))">
                                            <div class="item-name">
                                                @product.Name <span class="sku-tag">@product.Sku</span>
                                                @if (p.Quantity == 0)
                                                {
                                                    <span class="oos-badge">Out of Stock</span>
                                                }
                                            </div>
                                            <div class="item-meta">
                                                <span>Rs. @product.SalePrice.ToString("N0")</span>
                                                <span class="stock @(product.Quantity == 0 ? "oos" : product.Quantity < 5 ? "low" : "")">
                                                    Stock: @product.Quantity
                                                </span>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }

                        @if (showDropdown && !string.IsNullOrWhiteSpace(productSearch) && searchResults.Count == 0)
                        {
                            <div class="dropdown">
                                <div class="dropdown-empty">No products found.</div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Manual Item Entry (collapsible) -->
                @if (showManualEntry)
                {
                    <div class="manual-entry-panel">
                        <div class="manual-entry-label">Manual / Custom Item</div>
                        <div class="manual-entry-bar">
                            <input type="text"
                                   class="manual-input @(nameError ? "input-error" : "")"
                                   placeholder="Custom item name..."
                                   value="@manualItemName"
                                   @oninput="@((e) => { manualItemName = e.Value?.ToString() ?? ""; nameError = false; })" />
                            <input type="number"
                                   class="manual-price-input"
                                   placeholder="Price"
                                   @bind="manualItemPrice" />
                            <button class="btn-add-manual" @onclick="AddManualItem">
                                + Add
                            </button>
                        </div>
                        @if (nameError)
                        {
                            <div class="manual-error">Item name is required.</div>
                        }
                    </div>
                }

                <!-- Items Table -->
                @if (billItems.Count == 0)
                {
                    <div class="items-empty">
                        <p>No products added yet. Search above to add items.</p>
                    </div>
                }
                else
                {
                    <table class="items-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Unit Price</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in billItems)
                            {
                                <tr class="@(item == lastAddedItem ? "row-highlight" : "")">
                                    <td>
                                        <div class="product-cell">
                                            <span class="prod-name">@item.ProductName</span>
                                            @if (!string.IsNullOrEmpty(item.VariantName))
                                            {
                                                <span class="variant-chip">@item.VariantName</span>
                                            }
                                            @if (item.ProductId == Guid.Empty)
                                            {
                                                <span class="manual-chip">Manual</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="qty-ctrl">
                                            <button @onclick="@(() => ChangeQty(item, -1))">−</button>
                                            <span>@item.Quantity</span>
                                            <button @onclick="@(() => ChangeQty(item, 1))">+</button>
                                        </div>
                                    </td>
                                    <td>
                                        <input type="number" class="price-input"
                                               value="@item.UnitPrice"
                                               @onchange="@((e) => UpdatePrice(item, e))" />
                                    </td>
                                    <td class="total-cell">Rs. @((item.UnitPrice * item.Quantity).ToString("N0"))</td>
                                    <td>
                                        <button class="btn-remove" @onclick="@(() => RemoveItem(item))">✕</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- RIGHT: Summary -->
        <div class="right-col">
            <div class="section-card summary-card">
                <div class="section-title">Bill Summary</div>
                <div class="bill-no-display">
                    <span class="label">Bill No.</span>
                    <span class="value mono">Auto-generated on save</span>
                </div>
                <div class="bill-no-display">
                    <span class="label">Date</span>
                    <span class="value">@DateTime.Now.ToString("dd MMM yyyy")</span>
                </div>

                <div class="divider"></div>

                <!-- Live item count -->
                <div class="summary-row items-count-row">
                    <span>Items</span>
                    <span class="items-badge">@billItems.Count item@(billItems.Count == 1 ? "" : "s")</span>
                </div>

                @if (billItems.Count > 0)
                {
                    <div class="summary-items-list">
                        @foreach (var item in billItems)
                        {
                            <div class="summary-item-row">
                                <span class="si-name">
                                    @item.ProductName
                                    @if (!string.IsNullOrEmpty(item.VariantName))
                                    {
                                        <span class="si-variant"> (@item.VariantName)</span>
                                    }
                                </span>
                                <span class="si-detail">@item.Quantity × Rs. @item.UnitPrice.ToString("N0")</span>
                                <span class="si-total">Rs. @((item.UnitPrice * item.Quantity).ToString("N0"))</span>
                            </div>
                        }
                    </div>
                }

                <div class="divider"></div>

                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>Rs. @SubTotal.ToString("N0")</span>
                </div>
                <div class="summary-row">
                    <span>Discount</span>
                    <div class="discount-input-wrap">
                        <input type="number" min="0" class="discount-input"
                               value="@discountAmount"
                               @oninput="@((e) => { if (decimal.TryParse(e.Value?.ToString(), out var d)) discountAmount = d; })" />
                        <span>Rs.</span>
                    </div>
                </div>
                <div class="summary-row grand-total">
                    <span>Total</span>
                    <span>Rs. @GrandTotal.ToString("N0")</span>
                </div>

                <div class="divider"></div>

                <div class="form-field">
                    <label>Payment Status</label>
                    <select @bind="paymentStatus">
                        <option value="@PaymentStatus.Unpaid">Unpaid</option>
                        <option value="@PaymentStatus.Paid">Paid</option>
                        <option value="@PaymentStatus.PartiallyPaid">Partially Paid</option>
                    </select>
                </div>

                <div class="form-field">
                    <label>Payment Method</label>
                    <select @bind="paymentMethod">
                        <option value="@PaymentMethod.Cash">Cash</option>
                        <option value="@PaymentMethod.Card">Card</option>
                        <option value="@PaymentMethod.Online">Online Transfer</option>
                    </select>
                </div>

                <div class="divider"></div>

                <button class="btn-save-full" @onclick="SaveBill"
                        disabled="@(billItems.Count == 0 || isSaving)">
                    @(isSaving ? "Saving..." : "Save Bill")
                </button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="toast toast-error">@errorMessage</div>
}

<!-- ===================== OUT OF STOCK WARNING DIALOG ===================== -->
@if (showOutOfStockDialog)
{
    <div class="dialog-overlay" @onclick="CloseOutOfStockDialog">
        <div class="dialog-box dialog-warning" @onclick:stopPropagation="true">
            <div class="dialog-icon">⚠️</div>
            <div class="dialog-title">Out of Stock</div>
            <div class="dialog-message">
                <strong>@outOfStockProductName</strong> is currently out of stock and cannot be added to this bill.
            </div>
            <div class="dialog-actions">
                <button class="btn-dialog-primary" @onclick="CloseOutOfStockDialog">OK, Got it</button>
            </div>
        </div>
    </div>
}

<!-- ===================== ITEM ADDED SUCCESS DIALOG ===================== -->
@if (showItemAddedDialog)
{
    <div class="dialog-overlay" @onclick="CloseItemAddedDialog">
        <div class="dialog-box dialog-success" @onclick:stopPropagation="true">
            <div class="dialog-icon">✅</div>
            <div class="dialog-title">Item Added</div>
            <div class="dialog-message">
                <strong>@addedItemName</strong> has been added to the bill.
            </div>
            <div class="dialog-actions">
                <button class="btn-dialog-primary" @onclick="CloseItemAddedDialog">Continue</button>
            </div>
        </div>
    </div>
}

@code {
    private string manualItemName = "";
    private decimal manualItemPrice = 0;
    private string customerName = "";
    private string customerPhone = "";
    private string notes = "";
    private string productSearch = "";
    private decimal discountAmount = 0;
    private PaymentStatus paymentStatus = PaymentStatus.Unpaid;
    private PaymentMethod paymentMethod = PaymentMethod.Cash;
    private bool isSaving = false;
    private bool showDropdown = false;
    private string errorMessage = "";
    private bool nameError = false;
    private bool showManualEntry = false;

    // Dialog states
    private bool showOutOfStockDialog = false;
    private string outOfStockProductName = "";

    private bool showItemAddedDialog = false;
    private string addedItemName = "";

    // For row highlight animation
    private BillItem? lastAddedItem = null;

    private List<BillItem> billItems = new();
    private List<ProductDto> searchResults = new();
    private List<ProductDto> allProducts = new();

    private decimal SubTotal => billItems.Sum(i => i.UnitPrice * i.Quantity);
    private decimal GrandTotal => Math.Max(0, SubTotal - discountAmount);

    protected override async Task OnInitializedAsync()
    {
        allProducts = await ProductService.GetAllAsync();

        // Pre-fill items from cart if any
        foreach (var item in CartService.Items)
        {
            var existing = billItems.FirstOrDefault(i =>
                i.ProductId == item.ProductId &&
                i.ProductVariantId == item.VariantId);

            if (existing != null)
            {
                existing.Quantity += item.Quantity;
            }
            else
            {
                billItems.Add(new BillItem
                {
                    ProductId = item.ProductId,
                    ProductVariantId = item.VariantId,
                    ProductName = item.Name,
                    VariantName = item.VariantName,
                    UnitPrice = item.UnitPrice,
                    CostPrice = item.CostPrice,
                    Quantity = item.Quantity
                });
            }
        }

        CartService.Clear();
        // No RecalculateTotals needed — SubTotal and GrandTotal are computed properties
    }

    private void ToggleManualEntry()
    {
        showManualEntry = !showManualEntry;
    }

    private void SearchProducts(ChangeEventArgs e)
    {
        productSearch = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(productSearch))
        {
            searchResults.Clear();
            return;
        }
        searchResults = allProducts
            .Where(p => p.Name.Contains(productSearch, StringComparison.OrdinalIgnoreCase)
                     || p.Sku.Contains(productSearch, StringComparison.OrdinalIgnoreCase))
            .Take(8)
            .ToList();
        showDropdown = true;
    }

    private void HideDropdown()
    {
        Task.Delay(150).ContinueWith(_ =>
        {
            showDropdown = false;
            InvokeAsync(StateHasChanged);
        });
    }

    // --- Out of Stock Dialog ---
    private void ShowOutOfStockWarning(string productName)
    {
        outOfStockProductName = productName;
        showOutOfStockDialog = true;
        ClearSearch();
    }

    private void CloseOutOfStockDialog()
    {
        showOutOfStockDialog = false;
        outOfStockProductName = "";
    }

    // --- Item Added Dialog ---
    private async Task ShowItemAddedSuccess(string itemName)
    {
        addedItemName = itemName;
        showItemAddedDialog = true;
        StateHasChanged();
        // Auto-close after 2 seconds
        await Task.Delay(2000);
        if (showItemAddedDialog)
        {
            showItemAddedDialog = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void CloseItemAddedDialog()
    {
        showItemAddedDialog = false;
        addedItemName = "";
    }

    // --- Add from search with out-of-stock check ---
    private async Task TryAddItem(ProductDto product)
    {
        errorMessage = "";

        var existingQty = billItems
            .Where(i => i.ProductId == product.Id && !i.ProductVariantId.HasValue)
            .Sum(i => i.Quantity);

        if (product.Quantity <= 0)
        {
            ShowOutOfStockWarning(product.Name);
            return;
        }

        if (existingQty >= product.Quantity)
        {
            errorMessage = $"Only {product.Quantity} item(s) available for {product.Name}.";
            ClearSearch();
            return;
        }

        AddItem(product);
        await ShowItemAddedSuccess(product.Name);
    }

    private async Task TryAddItemFromVariant(ProductDto product, ProductVariantDto variant)
    {
        errorMessage = "";

        var existingQty = billItems
            .Where(i => i.ProductId == product.Id && i.ProductVariantId == variant.Id)
            .Sum(i => i.Quantity);

        if (variant.Quantity <= 0)
        {
            ShowOutOfStockWarning($"{product.Name} ({variant.Name})");
            return;
        }

        if (existingQty >= variant.Quantity)
        {
            errorMessage = $"Only {variant.Quantity} item(s) available for {product.Name} ({variant.Name}).";
            ClearSearch();
            return;
        }

        AddItemFromVariant(product, variant);
        await ShowItemAddedSuccess($"{product.Name} ({variant.Name})");
    }

    private void AddItem(ProductDto product)
    {
        var existing = billItems.FirstOrDefault(i =>
            i.ProductId == product.Id && i.ProductVariantId == null);

        if (existing != null)
        {
            existing.Quantity++;
            lastAddedItem = existing;
        }
        else
        {
            var newItem = new BillItem
            {
                ProductId = product.Id,
                ProductName = product.Name,
                UnitPrice = product.SalePrice,
                CostPrice = product.CostPrice,
                Quantity = 1
            };
            billItems.Add(newItem);
            lastAddedItem = newItem;
        }
        ClearSearch();
    }

    private void AddItemFromVariant(ProductDto product, ProductVariantDto variant)
    {
        var existing = billItems.FirstOrDefault(i =>
            i.ProductId == product.Id && i.ProductVariantId == variant.Id);

        if (existing != null)
        {
            existing.Quantity++;
            lastAddedItem = existing;
        }
        else
        {
            var newItem = new BillItem
            {
                ProductId = product.Id,
                ProductVariantId = variant.Id,
                ProductName = product.Name,
                VariantName = variant.Name,
                UnitPrice = variant.SalePrice,
                CostPrice = variant.CostPrice,
                Quantity = 1
            };
            billItems.Add(newItem);
            lastAddedItem = newItem;
        }
        ClearSearch();
    }

    private void ClearSearch()
    {
        productSearch = "";
        searchResults.Clear();
        showDropdown = false;
    }

    private void ChangeQty(BillItem item, int delta)
    {
        errorMessage = "";

        var newQty = item.Quantity + delta;

        if (newQty < 1)
        {
            item.Quantity = 1;
            return;
        }

        // Manual items have no stock control
        if (item.ProductId == Guid.Empty)
        {
            item.Quantity = newQty;
            return;
        }

        int availableStock = GetAvailableStock(item);

        if (delta > 0 && newQty > availableStock)
        {
            errorMessage = $"Only {availableStock} item(s) available for {item.ProductName}.";
            return;
        }

        item.Quantity = newQty;
    }
    private int GetAvailableStock(BillItem item)
    {
        var product = allProducts.FirstOrDefault(p => p.Id == item.ProductId);
        if (product == null)
            return 0;

        if (item.ProductVariantId.HasValue)
        {
            var variant = product.Variants?.FirstOrDefault(v => v.Id == item.ProductVariantId.Value);
            return variant?.Quantity ?? 0;
        }

        return product.Quantity;
    }

    private void UpdatePrice(BillItem item, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var price))
            item.UnitPrice = price;
    }

    private void RemoveItem(BillItem item) => billItems.Remove(item);

    private async Task SaveBill()
    {
        if (billItems.Count == 0) return;
        isSaving = true;
        try
        {
            var bill = new Bill
            {
                CustomerName = string.IsNullOrWhiteSpace(customerName) ? null : customerName,
                CustomerPhone = string.IsNullOrWhiteSpace(customerPhone) ? null : customerPhone,
                Notes = string.IsNullOrWhiteSpace(notes) ? null : notes,
                DiscountAmount = discountAmount,
                PaymentStatus = paymentStatus,
                PaymentMethod = paymentMethod,
                Items = billItems
            };

            var saved = await BillService.CreateBillAsync(bill);
            Navigation.NavigateTo($"/billing/{saved.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving bill: {ex.Message}";
            isSaving = false;
        }
    }

    private void SaveDraft()
    {
        // Optional: implement draft save logic
    }

    private void GoBack() => Navigation.NavigateTo("/billing");

    private async Task AddManualItem()
    {
        if (string.IsNullOrWhiteSpace(manualItemName))
        {
            nameError = true;
            return;
        }
        if (manualItemPrice <= 0) return;

        var existing = billItems.FirstOrDefault(i =>
            i.ProductName == manualItemName.Trim() &&
            i.ProductId == Guid.Empty &&
            i.ProductVariantId == null);

        string itemLabel = manualItemName.Trim();

        if (existing != null)
        {
            existing.Quantity++;
            lastAddedItem = existing;
        }
        else
        {
            var newItem = new BillItem
            {
                ProductId = Guid.Empty,
                ProductName = manualItemName.Trim(),
                UnitPrice = manualItemPrice,
                CostPrice = 0,
                Quantity = 1
            };
            billItems.Add(newItem);
            lastAddedItem = newItem;
        }

        nameError = false;
        manualItemName = "";
        manualItemPrice = 0;

        await ShowItemAddedSuccess(itemLabel);
    }

}
