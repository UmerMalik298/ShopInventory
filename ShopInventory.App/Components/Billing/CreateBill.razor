@page "/billing/create"
@page "/billing/create/{DraftId:guid}"
@using ShopInventory.Domain.Entities.Sales
@using ShopInventory.Domain.Entities.Enums
@using ShopInventory.Domain.Entities.Billing
@using ShopInventory.Domain.Entities.Products
@using ShopInventory.Application.DTOs
@using ShopInventory.Application.Interfaces
@inject IBillService BillService
@inject IProductService ProductService
@inject NavigationManager Navigation

<div class="create-bill-page">

    <!-- Top Bar -->
    <div class="top-bar">
        <button class="btn-back" @onclick="GoBack">&#8592; Back</button>
        <h2>@(isDraftMode ? "Edit Draft" : "New Bill")</h2>
        <div class="top-actions">
            <button class="btn-outline" @onclick="SaveDraft" disabled="@isSaving">
                @(isSaving && savingAsDraft ? "Saving..." : "Save Draft")
            </button>
            <button class="btn-primary" @onclick="SaveBill" disabled="@(billItems.Count == 0 || isSaving)">
                @(isSaving && !savingAsDraft ? "Saving..." : isDraftMode ? "Finalise Bill" : "Save Bill")
            </button>
        </div>
    </div>

    <div class="bill-layout">

        <!-- LEFT -->
        <div class="left-col">

            <!-- Draft badge -->
            @if (isDraftMode)
            {
                <div class="draft-banner">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9" /><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" /></svg>
                    Editing draft — click <strong>Finalise Bill</strong> to save and deduct stock.
                </div>
            }

            <!-- Customer Info -->
            <div class="section-card">
                <div class="section-title">Customer Info</div>
                <div class="form-row">
                    <div class="form-field">
                        <label>Customer Name</label>
                        <input type="text" placeholder="Walk-in customer" @bind="customerName" />
                    </div>
                    <div class="form-field" style="max-width:180px">
                        <label>Phone Number</label>
                        <input type="text" placeholder="+92 300 0000000" @bind="customerPhone" />
                    </div>
                </div>
                <div class="form-field">
                    <label>Notes (optional)</label>
                    <input type="text" placeholder="Any notes for this bill..." @bind="notes" />
                </div>
            </div>

            <!-- Add Products -->
            <div class="section-card">
                <div class="add-products-header">
                    <div class="section-title" style="margin-bottom:0">Add Products</div>
                    <button class="btn-manual-toggle @(showManual ? "active" : "")"
                            @onclick="@(() => showManual = !showManual)">
                        @if (showManual)
                        {
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                            <span>Cancel</span>
                        }
                        else
                        {
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                            <span>Manual Item</span>
                        }
                    </button>
                </div>

                <!-- Search -->
                <div class="search-area" style="margin-top:14px">
                    <div class="search-wrap">
                        <input type="text"
                               placeholder="Search product by name or SKU..."
                               value="@productSearch"
                               @oninput="SearchProducts"
                               @onfocus="@(() => showDropdown = true)"
                               @onblur="HideDropdown" />

                        @if (showDropdown && searchResults.Count > 0)
                        {
                            <div class="dropdown">
                                @foreach (var product in searchResults)
                                {
                                    @if (product.HasVariants)
                                    {
                                        @foreach (var variant in product.Variants)
                                        {
                                            var p = product; var v = variant;
                                            bool oos = v.Quantity <= 0;
                                            <div class="dropdown-item @(oos ? "item-oos" : "")"
                                                 @onmousedown="@(() => HandleVariantClick(p, v))">
                                                <div class="item-name">
                                                    @p.Name <span class="variant-tag">@v.Name</span>
                                                    @if (oos)
                                                    {
                                                        <span class="oos-badge">Out of Stock</span>
                                                    }
                                                </div>
                                                <div class="item-meta">
                                                    <span>Rs. @v.SalePrice.ToString("N0")</span>
                                                    <span class="stock @(oos ? "oos" : v.Quantity < 5 ? "low" : "")">Stock: @v.Quantity</span>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        var p = product;
                                        bool oos = p.Quantity <= 0;
                                        <div class="dropdown-item @(oos ? "item-oos" : "")"
                                             @onmousedown="@(() => HandleProductClick(p))">
                                            <div class="item-name">
                                                @p.Name <span class="sku-tag">@p.Sku</span>
                                                @if (oos)
                                                {
                                                    <span class="oos-badge">Out of Stock</span>
                                                }
                                            </div>
                                            <div class="item-meta">
                                                <span>Rs. @p.SalePrice.ToString("N0")</span>
                                                <span class="stock @(oos ? "oos" : p.Quantity < 5 ? "low" : "")">Stock: @p.Quantity</span>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Manual panel -->
                @if (showManual)
                {
                    <div class="manual-panel">
                        <span class="manual-panel-label">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9" /><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" /></svg>
                            Custom / unlisted item
                        </span>
                        <div class="manual-entry-bar">
                            <input type="text"
                                   class="@(nameError ? "input-error" : "")"
                                   placeholder="Custom item name..."
                                   value="@manualName"
                                   @oninput="@((e) => { manualName = e.Value?.ToString() ?? ""; nameError = false; })" />
                            <input type="number" placeholder="Price" @bind="manualPrice" />
                            <button @onclick="AddManualItem">+ Add</button>
                        </div>
                    </div>
                }

                <!-- Items Table -->
                @if (billItems.Count == 0)
                {
                    <div class="items-empty">
                        <p>No products added yet. Search above to add items.</p>
                    </div>
                }
                else
                {
                    <table class="items-table">
                        <thead>
                            <tr><th>Product</th><th>Qty</th><th>Unit Price</th><th>Total</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in billItems)
                            {
                                <tr class="@(item == _lastAdded ? "row-flash" : "")">
                                    <td>
                                        <div class="product-cell">
                                            <span class="prod-name">@item.ProductName</span>
                                            @if (!string.IsNullOrEmpty(item.VariantName))
                                            {
                                                <span class="variant-chip">@item.VariantName</span>
                                            }
                                            @if (item.ProductId == Guid.Empty)
                                            {
                                                <span class="manual-chip">manual</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        @{
                                            var atMax = item.ProductId != Guid.Empty &&
                                            _stockLimits.TryGetValue(StockKey(item.ProductId, item.ProductVariantId), out var maxQ) &&
                                            item.Quantity >= maxQ;
                                        }
                                        <div class="qty-ctrl">
                                            <button @onclick="@(() => ChangeQty(item, -1))">−</button>
                                            <span>@item.Quantity</span>
                                            <button @onclick="@(() => ChangeQty(item, 1))"
                                                    disabled="@atMax"
                                                    style="@(atMax ? "opacity:0.4;cursor:not-allowed;" : "")">
                                                +
                                            </button>
                                        </div>
                                    </td>
                                    <td>
                                        <input type="number" class="price-input"
                                               value="@item.UnitPrice"
                                               @onchange="@((e) => UpdatePrice(item, e))" />
                                    </td>
                                    <td class="total-cell">Rs. @((item.UnitPrice * item.Quantity).ToString("N0"))</td>
                                    <td><button class="btn-remove" @onclick="@(() => billItems.Remove(item))">✕</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- RIGHT: Summary -->
        <div class="right-col">
            <div class="section-card summary-card">
                <div class="section-title">Bill Summary</div>
                <div class="bill-no-display">
                    <span class="label">Bill No.</span>
                    <span class="value mono">@(isDraftMode? currentDraftBillNo : "Auto-generated on save")</span>
                </div>
                <div class="bill-no-display">
                    <span class="label">Date</span>
                    <span class="value">@DateTime.Now.ToString("dd MMM yyyy")</span>
                </div>
                <div class="divider"></div>

                @if (billItems.Count > 0)
                {
                    <div class="summary-items">
                        @foreach (var item in billItems)
                        {
                            <div class="summary-item @(item == _lastAdded ? "summary-item-flash" : "")">
                                <div class="si-name">
                                    @item.ProductName
                                    @if (!string.IsNullOrEmpty(item.VariantName))
                                    {
                                        <span class="si-variant">@item.VariantName</span>
                                    }
                                    <span class="si-qty">×@item.Quantity</span>
                                </div>
                                <span class="si-price">Rs. @((item.UnitPrice * item.Quantity).ToString("N0"))</span>
                            </div>
                        }
                    </div>
                    <div class="divider"></div>
                }

                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>Rs. @SubTotal.ToString("N0")</span>
                </div>
                <div class="summary-row">
                    <span>Discount</span>
                    <div class="discount-input-wrap">
                        <input type="number" min="0" class="discount-input"
                               value="@discountAmount"
                               @oninput="@((e) => { if (decimal.TryParse(e.Value?.ToString(), out var d)) discountAmount = d; })" />
                        <span>Rs.</span>
                    </div>
                </div>
                <div class="summary-row grand-total">
                    <span>Total</span>
                    <span>Rs. @GrandTotal.ToString("N0")</span>
                </div>
                <div class="divider"></div>

                <div class="form-field">
                    <label>Payment Status</label>
                    <select @bind="paymentStatus">
                        <option value="@PaymentStatus.Unpaid">Unpaid</option>
                        <option value="@PaymentStatus.Paid">Paid</option>
                        <option value="@PaymentStatus.PartiallyPaid">Partially Paid</option>
                    </select>
                </div>
                <div class="form-field">
                    <label>Payment Method</label>
                    <select @bind="paymentMethod">
                        <option value="@PaymentMethod.Cash">Cash</option>
                        <option value="@PaymentMethod.Card">Card</option>
                        <option value="@PaymentMethod.Online">Online Transfer</option>
                    </select>
                </div>
                <div class="divider"></div>

                <button class="btn-save-full" @onclick="SaveBill"
                        disabled="@(billItems.Count == 0 || isSaving)">
                    @(isSaving && !savingAsDraft ? "Saving..." : isDraftMode ? "Finalise Bill" : "Save Bill")
                </button>
            </div>
        </div>
    </div>
</div>

<!-- WhatsApp Share Dialog -->
@if (showWhatsAppDialog)
{
    <div class="wa-overlay" @onclick="CloseWhatsApp">
        <div class="wa-dialog" @onclick:stopPropagation="true">
            <div class="wa-header">
                <div class="wa-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
                    </svg>
                </div>
                <div>
                    <div class="wa-title">Share via WhatsApp</div>
                    <div class="wa-subtitle">Send the bill receipt as a message</div>
                </div>
            </div>

            <div class="wa-body">
                @if (!string.IsNullOrWhiteSpace(customerPhone))
                {
                    <button class="wa-option-btn @(waUseCustomerPhone ? "selected" : "")"
                            @onclick="@(() => { waUseCustomerPhone = true; waCustomPhone = ""; })">
                        <div class="wa-option-label">Send to customer</div>
                        <div class="wa-option-val">@customerPhone</div>
                    </button>
                }

                <button class="wa-option-btn @(!waUseCustomerPhone ? "selected" : "")"
                        @onclick="@(() => waUseCustomerPhone = false)">
                    <div class="wa-option-label">Enter a different number</div>
                    @if (!waUseCustomerPhone)
                    {
                        <input type="tel"
                               class="wa-phone-input"
                               placeholder="+92 300 0000000"
                               value="@waCustomPhone"
                               @oninput="@((e) => waCustomPhone = e.Value?.ToString() ?? "")"
                               @onclick:stopPropagation="true" />
                    }
                </button>
            </div>

            <div class="wa-actions">
                <button class="wa-btn-cancel" @onclick="CloseWhatsApp">Cancel</button>
                <button class="wa-btn-send" @onclick="SendWhatsApp">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
                    </svg>
                    Open WhatsApp
                </button>
            </div>
        </div>
    </div>
}

<OutOfStockWarningDialog @ref="_oosDialog" />
<ItemAddedToast @ref="_addedToast" />

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="toast toast-error">@errorMessage</div>
}

<style>
    .draft-banner {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #fffbeb;
        border: 1px solid #fde68a;
        color: #92400e;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 13px;
        margin-bottom: 14px;
    }

    .add-products-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0;
    }

    .btn-manual-toggle {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        font-size: 12.5px;
        font-weight: 500;
        border-radius: 8px;
        border: 1.5px dashed #c7d2fe;
        background: transparent;
        color: #6366f1;
        cursor: pointer;
        transition: all .16s ease;
    }

        .btn-manual-toggle:hover {
            background: #eef2ff;
            border-color: #6366f1;
        }

        .btn-manual-toggle.active {
            border-style: solid;
            border-color: #ef4444;
            color: #ef4444;
            background: #fff5f5;
        }

    .manual-panel {
        margin-top: 12px;
        padding: 12px 14px 14px;
        background: #fafbff;
        border: 1.5px dashed #c7d2fe;
        border-radius: 10px;
        animation: mpSlide .18s ease;
    }

    @@keyframes mpSlide {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .manual-panel-label {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: #6366f1;
        margin-bottom: 10px;
    }

    .manual-entry-bar {
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .manual-entry-bar input[type="text"] {
            flex: 1;
        }

        .manual-entry-bar input[type="number"] {
            width: 100px;
        }

        .manual-entry-bar button {
            padding: 8px 16px;
            background: #0f172a;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
        }

            .manual-entry-bar button:hover {
                background: #1e293b;
            }

    .item-oos {
        opacity: .5;
        cursor: not-allowed;
    }

    .oos-badge {
        font-size: 10px;
        font-weight: 600;
        padding: 1px 6px;
        border-radius: 4px;
        background: #fee2e2;
        color: #dc2626;
        margin-left: 6px;
    }

    .stock.oos {
        color: #dc2626;
        font-weight: 600;
    }

    .stock.low {
        color: #f59e0b;
        font-weight: 600;
    }

    .row-flash {
        animation: rowFlash 2s ease forwards;
    }

    @@keyframes rowFlash {
        0%, 60% {
            background: #ecfdf5;
        }

        100% {
            background: transparent;
        }
    }

    .manual-chip {
        font-size: 10px;
        font-weight: 600;
        padding: 1px 6px;
        border-radius: 4px;
        background: #ede9fe;
        color: #7c3aed;
        margin-left: 5px;
        vertical-align: middle;
    }

    .summary-items {
        display: flex;
        flex-direction: column;
        gap: 5px;
        max-height: 200px;
        overflow-y: auto;
        margin-bottom: 12px;
    }

    .summary-item {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        font-size: 13px;
        color: #374151;
        padding: 3px 6px;
        border-radius: 6px;
    }

    .summary-item-flash {
        animation: siFlash 2.2s ease forwards;
    }

    @@keyframes siFlash {
        0%, 65% {
            background: #d1fae5;
        }

        100% {
            background: transparent;
        }
    }

    .si-name {
        display: flex;
        align-items: center;
        gap: 5px;
        flex-wrap: wrap;
        max-width: 60%;
    }

    .si-variant {
        font-size: 11px;
        color: #6b7280;
        background: #f3f4f6;
        border-radius: 4px;
        padding: 1px 5px;
    }

    .si-qty {
        font-size: 11.5px;
        color: #9ca3af;
    }

    .si-price {
        font-weight: 500;
        color: #111827;
        white-space: nowrap;
    }

    /* WhatsApp Dialog */
    .wa-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.45);
        backdrop-filter: blur(3px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 99999;
        padding: 1rem;
        animation: waIn .15s ease;
    }

    @@keyframes waIn {
        from {
            opacity: 0
        }

        to {
            opacity: 1
        }
    }

    .wa-dialog {
        background: #fff;
        border-radius: 18px;
        padding: 24px;
        max-width: 380px;
        width: 100%;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
        animation: waPop .22s cubic-bezier(.34,1.56,.64,1);
    }

    @@keyframes waPop {
        from {
            transform: scale(.88);
            opacity: 0
        }

        to {
            transform: scale(1);
            opacity: 1
        }
    }

    .wa-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
    }

    .wa-icon {
        width: 46px;
        height: 46px;
        background: #dcfce7;
        color: #16a34a;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .wa-title {
        font-size: 16px;
        font-weight: 700;
        color: #111;
    }

    .wa-subtitle {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 2px;
    }

    .wa-body {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 20px;
    }

    .wa-option-btn {
        text-align: left;
        padding: 12px 14px;
        border: 1.5px solid #e5e7eb;
        border-radius: 12px;
        background: #fff;
        cursor: pointer;
        transition: all .15s;
        width: 100%;
    }

        .wa-option-btn:hover {
            border-color: #22c55e;
            background: #f0fdf4;
        }

        .wa-option-btn.selected {
            border-color: #22c55e;
            background: #f0fdf4;
        }

    .wa-option-label {
        font-size: 11px;
        font-weight: 600;
