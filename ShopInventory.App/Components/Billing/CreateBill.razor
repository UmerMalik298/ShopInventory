@page "/billing/create"
@using ShopInventory.Domain.Entities.Sales
@using ShopInventory.Domain.Entities.Enums
@using ShopInventory.Domain.Entities.Billing
@using ShopInventory.Domain.Entities.Products
@using ShopInventory.Application.DTOs
@using ShopInventory.Application.Interfaces
@inject IBillService BillService
@inject IProductService ProductService
@inject NavigationManager Navigation

<div class="create-bill-page">

    <!-- Top Bar -->
    <div class="top-bar">
        <button class="btn-back" @onclick="GoBack">&#8592; Back</button>
        <h2>New Bill</h2>
        <div class="top-actions">
            <button class="btn-outline" @onclick="SaveDraft" @disabled="isSaving">Save Draft</button>
            <button class="btn-primary" @onclick="SaveBill" @disabled="(billItems.Count == 0 || isSaving)">
                @(isSaving ? "Saving..." : "Save Bill")
            </button>
        </div>
    </div>

    <div class="bill-layout">

        <!-- LEFT: Customer + Items -->
        <div class="left-col">

            <!-- Customer Info -->
            <div class="section-card">
                <div class="section-title">Customer Info</div>
                <div class="form-row">
                    <div class="form-field">
                        <label>Customer Name</label>
                        <input type="text" placeholder="Walk-in customer" @bind="customerName" />
                    </div>
                    <div class="form-field" style="max-width:180px">
                        <label>Phone Number</label>
                        <input type="text" placeholder="+92 300 0000000" @bind="customerPhone" />
                    </div>
                </div>
                <div class="form-field">
                    <label>Notes (optional)</label>
                    <input type="text" placeholder="Any notes for this bill..." @bind="notes" />
                </div>
            </div>

            <!-- Add Items -->
            <div class="section-card">
                <div class="section-title">Add Products</div>

                <!-- Product Search -->
                <div class="search-area">
                    <div class="search-wrap">
                        <input type="text"
                               placeholder="Search product by name or SKU..."
                               value="@productSearch"
                               @oninput="SearchProducts"
                               @onfocus="@(() => showDropdown = true)"
                               @onblur="HideDropdown" />

                        @if (showDropdown && searchResults.Count > 0)
                        {
                            <div class="dropdown">
                                @foreach (var product in searchResults)
                                {
                                    @if (product.HasVariants)
                                    {
                                        @foreach (var variant in product.Variants)
                                        {
                                            var p = product;
                                            var v = variant;
                                            <div class="dropdown-item" @onmousedown="@(() => AddItemFromVariant(p, v))">
                                                <div class="item-name">@product.Name <span class="variant-tag">@variant.Name</span></div>
                                                <div class="item-meta">
                                                    <span>Rs. @variant.SalePrice.ToString("N0")</span>
                                                    <span class="stock @(variant.Quantity < 5 ? "low" : "")">Stock: @variant.Quantity</span>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        var p = product;
                                        <div class="dropdown-item" @onmousedown="@(() => AddItem(p))">
                                            <div class="item-name">@product.Name <span class="sku-tag">@product.Sku</span></div>
                                            <div class="item-meta">
                                                <span>Rs. @product.SalePrice.ToString("N0")</span>
                                                <span class="stock @(product.Quantity < 5 ? "low" : "")">Stock: @product.Quantity</span>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Items Table -->
                @if (billItems.Count == 0)
                {
                    <div class="items-empty">
                        <p>No products added yet. Search above to add items.</p>
                    </div>
                }
                else
                {
                    <table class="items-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Unit Price</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in billItems)
                            {
                                <tr>
                                    <td>
                                        <div class="product-cell">
                                            <span class="prod-name">@item.ProductName</span>
                                            @if (!string.IsNullOrEmpty(item.VariantName))
                                            {
                                                <span class="variant-chip">@item.VariantName</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="qty-ctrl">
                                            <button @onclick="@(() => ChangeQty(item, -1))">−</button>
                                            <span>@item.Quantity</span>
                                            <button @onclick="@(() => ChangeQty(item, 1))">+</button>
                                        </div>
                                    </td>
                                    <td>
                                        <input type="number" class="price-input"
                                               value="@item.UnitPrice"
                                               @onchange="@((e) => UpdatePrice(item, e))" />
                                    </td>
                                    <td class="total-cell">Rs. @((item.UnitPrice * item.Quantity).ToString("N0"))</td>
                                    <td>
                                        <button class="btn-remove" @onclick="@(() => RemoveItem(item))">✕</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- RIGHT: Summary -->
        <div class="right-col">
            <div class="section-card summary-card">
                <div class="section-title">Bill Summary</div>
                <div class="bill-no-display">
                    <span class="label">Bill No.</span>
                    <span class="value mono">Auto-generated on save</span>
                </div>
                <div class="bill-no-display">
                    <span class="label">Date</span>
                    <span class="value">@DateTime.Now.ToString("dd MMM yyyy")</span>
                </div>

                <div class="divider"></div>

                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>Rs. @SubTotal.ToString("N0")</span>
                </div>
                <div class="summary-row">
                    <span>Discount</span>
                    <div class="discount-input-wrap">
                        <input type="number" min="0" class="discount-input"
                               value="@discountAmount"
                               @oninput="@((e) => { if(decimal.TryParse(e.Value?.ToString(), out var d)) discountAmount = d; })" />
                        <span>Rs.</span>
                    </div>
                </div>
                <div class="summary-row grand-total">
                    <span>Total</span>
                    <span>Rs. @GrandTotal.ToString("N0")</span>
                </div>

                <div class="divider"></div>

                <div class="form-field">
                    <label>Payment Status</label>
                    <select @bind="paymentStatus">
                        <option value="@PaymentStatus.Unpaid">Unpaid</option>
                        <option value="@PaymentStatus.Paid">Paid</option>
                        <option value="@PaymentStatus.PartiallyPaid">Partially Paid</option>
                    </select>
                </div>

                <div class="form-field">
                    <label>Payment Method</label>
                    <select @bind="paymentMethod">
                        <option value="@PaymentMethod.Cash">Cash</option>
                        <option value="@PaymentMethod.Card">Card</option>
                        <option value="@PaymentMethod.Online">Online Transfer</option>
                    </select>
                </div>

                <div class="divider"></div>

                <button class="btn-save-full" @onclick="SaveBill"
                        @disabled="(billItems.Count == 0 || isSaving)">
                    @(isSaving ? "Saving..." : "Save Bill")
                </button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="toast toast-error">@errorMessage</div>
}

@code {
    private string customerName = "";
    private string customerPhone = "";
    private string notes = "";
    private string productSearch = "";
    private decimal discountAmount = 0;
    private PaymentStatus paymentStatus = PaymentStatus.Unpaid;
    private PaymentMethod paymentMethod = PaymentMethod.Cash;
    private bool isSaving = false;
    private bool showDropdown = false;
    private string errorMessage = "";

    private List<BillItem> billItems = new();
    private List<ProductDto> searchResults = new();
    private List<ProductDto> allProducts = new();

    private decimal SubTotal => billItems.Sum(i => i.UnitPrice * i.Quantity);
    private decimal GrandTotal => Math.Max(0, SubTotal - discountAmount);

    protected override async Task OnInitializedAsync()
    {
        allProducts = await ProductService.GetAllAsync();
    }

    private void SearchProducts(ChangeEventArgs e)
    {
        productSearch = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(productSearch))
        {
            searchResults.Clear();
            return;
        }
        searchResults = allProducts
            .Where(p => p.Name.Contains(productSearch, StringComparison.OrdinalIgnoreCase)
                     || p.Sku.Contains(productSearch, StringComparison.OrdinalIgnoreCase))
            .Take(8)
            .ToList();
        showDropdown = true;
    }

    private void HideDropdown()
    {
        Task.Delay(150).ContinueWith(_ =>
        {
            showDropdown = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private void AddItem(ProductDto product)
    {
        var existing = billItems.FirstOrDefault(i =>
            i.ProductId == product.Id && i.ProductVariantId == null);

        if (existing != null) { existing.Quantity++; }
        else
        {
            billItems.Add(new BillItem
            {
                ProductId = product.Id,
                ProductName = product.Name,
                UnitPrice = product.SalePrice,
                CostPrice = product.CostPrice,
                Quantity = 1
            });
        }
        ClearSearch();
    }

    private void AddItemFromVariant(ProductDto product, ProductVariantDto variant)
    {
        var existing = billItems.FirstOrDefault(i =>
            i.ProductId == product.Id && i.ProductVariantId == variant.Id);

        if (existing != null) { existing.Quantity++; }
        else
        {
            billItems.Add(new BillItem
            {
                ProductId = product.Id,
                ProductVariantId = variant.Id,
                ProductName = product.Name,
                VariantName = variant.Name,
                UnitPrice = variant.SalePrice,
                CostPrice = variant.CostPrice,
                Quantity = 1
            });
        }
        ClearSearch();
    }

    private void ClearSearch()
    {
        productSearch = "";
        searchResults.Clear();
        showDropdown = false;
    }

    private void ChangeQty(BillItem item, int delta)
    {
        item.Quantity = Math.Max(1, item.Quantity + delta);
    }

    private void UpdatePrice(BillItem item, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var price))
            item.UnitPrice = price;
    }

    private void RemoveItem(BillItem item) => billItems.Remove(item);

    private async Task SaveBill()
    {
        if (billItems.Count == 0) return;
        isSaving = true;
        try
        {
            var bill = new Bill
            {
                CustomerName = string.IsNullOrWhiteSpace(customerName) ? null : customerName,
                CustomerPhone = string.IsNullOrWhiteSpace(customerPhone) ? null : customerPhone,
                Notes = string.IsNullOrWhiteSpace(notes) ? null : notes,
                DiscountAmount = discountAmount,
                PaymentStatus = paymentStatus,
                PaymentMethod = paymentMethod,
                Items = billItems
            };

            var saved = await BillService.CreateBillAsync(bill);
            Navigation.NavigateTo($"/billing/{saved.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving bill: {ex.Message}";
            isSaving = false;
        }
    }

    private void SaveDraft()
    {
        // Optional: implement draft save logic
    }

    private void GoBack() => Navigation.NavigateTo("/billing");
}

<style>
.create-bill-page { padding: 1rem 1.25rem; max-width: 1100px; margin: 0 auto; }

.top-bar { display: flex; align-items: center; gap: 12px; margin-bottom: 1.25rem; }
.top-bar h2 { flex: 1; font-size: 20px; font-weight: 600; margin: 0; }
.btn-back { background: none; border: none; font-size: 15px; color: #555; cursor: pointer; padding: 6px 10px;
    border-radius: 8px; }
.btn-back:hover { background: #f3f4f6; }
.top-actions { display: flex; gap: 8px; }

.btn-primary { background: #111; color: #fff; border: none; border-radius: 10px;
    padding: 9px 20px; font-size: 14px; font-weight: 500; cursor: pointer; transition: opacity .15s; }
.btn-primary:hover:not(:disabled) { opacity: .85; }
.btn-primary:disabled { opacity: .45; cursor: not-allowed; }
.btn-outline { background: transparent; color: #111; border: 1px solid #d1d5db; border-radius: 10px;
    padding: 9px 16px; font-size: 14px; cursor: pointer; }
.btn-outline:hover { background: #f9fafb; }

.bill-layout { display: grid; grid-template-columns: 1fr 320px; gap: 16px; align-items: start; }

.section-card { background: #fff; border: 1px solid #f0f0f0; border-radius: 14px;
    padding: 1.1rem 1.25rem; margin-bottom: 14px; }
.section-title { font-size: 13px; font-weight: 600; color: #9ca3af; text-transform: uppercase;
    letter-spacing: .05em; margin-bottom: 12px; }

.form-row { display: flex; gap: 10px; margin-bottom: 10px; }
.form-field { display: flex; flex-direction: column; gap: 5px; flex: 1; margin-bottom: 8px; }
.form-field label { font-size: 12px; color: #6b7280; font-weight: 500; }
.form-field input, .form-field select { padding: 8px 11px; border: 1px solid #e5e7eb;
    border-radius: 9px; font-size: 14px; color: #111; background: #f9fafb; outline: none; }
.form-field input:focus, .form-field select:focus { border-color: #9ca3af; background: #fff; }

.search-area { margin-bottom: 12px; }
.search-wrap { position: relative; }
.search-wrap input { width: 100%; padding: 9px 13px; border: 1px solid #e5e7eb; border-radius: 10px;
    font-size: 14px; background: #f9fafb; outline: none; color: #111; }
.search-wrap input:focus { border-color: #9ca3af; background: #fff; }

.dropdown { position: absolute; top: calc(100% + 4px); left: 0; right: 0; background: #fff;
    border: 1px solid #e5e7eb; border-radius: 11px; box-shadow: 0 8px 24px rgba(0,0,0,.09);
    z-index: 100; max-height: 280px; overflow-y: auto; }
.dropdown-item { padding: 10px 14px; cursor: pointer; transition: background .1s; border-bottom: 1px solid #f9fafb; }
.dropdown-item:last-child { border-bottom: none; }
.dropdown-item:hover { background: #f9fafb; }
.item-name { font-size: 14px; color: #111; font-weight: 500; }
.variant-tag { font-size: 11px; background: #ede9fe; color: #5b21b6; border-radius: 6px;
    padding: 1px 7px; margin-left: 6px; font-weight: 500; }
.sku-tag { font-size: 11px; background: #f0f9ff; color: #0369a1; border-radius: 6px;
    padding: 1px 7px; margin-left: 6px; font-family: monospace; }
.item-meta { display: flex; gap: 12px; font-size: 12px; color: #6b7280; margin-top: 2px; }
.stock.low { color: #ef4444; font-weight: 600; }

.items-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 4px; }
.items-table thead th { font-size: 11px; color: #9ca3af; font-weight: 600; text-align: left;
    padding: 6px 8px; border-bottom: 1px solid #f0f0f0; text-transform: uppercase; letter-spacing: .04em; }
.items-table tbody td { padding: 10px 8px; border-bottom: 1px solid #f9fafb; vertical-align: middle; }
.items-table tbody tr:last-child td { border-bottom: none; }

.product-cell { display: flex; flex-direction: column; gap: 3px; }
.prod-name { font-weight: 500; color: #111; }
.variant-chip { font-size: 11px; background: #ede9fe; color: #5b21b6; border-radius: 6px;
    padding: 1px 7px; width: fit-content; }

.qty-ctrl { display: flex; align-items: center; gap: 6px; }
.qty-ctrl button { width: 24px; height: 24px; border-radius: 50%; border: 1px solid #e5e7eb;
    background: #f9fafb; cursor: pointer; font-size: 15px; display: flex; align-items: center;
    justify-content: center; color: #374151; padding: 0; line-height: 1; }
.qty-ctrl button:hover { background: #f3f4f6; border-color: #d1d5db; }
.qty-ctrl span { font-weight: 600; min-width: 22px; text-align: center; }

.price-input { width: 90px; padding: 5px 8px; border: 1px solid #e5e7eb; border-radius: 8px;
    font-size: 13px; text-align: right; background: #f9fafb; color: #111; outline: none; }
.price-input:focus { border-color: #9ca3af; background: #fff; }
.total-cell { font-weight: 600; color: #111; text-align: right; }

.btn-remove { background: none; border: 1px solid #fee2e2; color: #ef4444; border-radius: 7px;
    padding: 4px 9px; font-size: 12px; cursor: pointer; }
.btn-remove:hover { background: #fee2e2; }

.items-empty { padding: 2rem 1rem; text-align: center; color: #9ca3af; font-size: 14px; }

/* Right summary card */
.summary-card { position: sticky; top: 1rem; }
.bill-no-display { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 8px; }
.bill-no-display .label { color: #6b7280; }
.bill-no-display .value { font-weight: 500; color: #111; }
.bill-no-display .mono { font-family: monospace; font-size: 12px; color: #9ca3af; }
.divider { border: none; border-top: 1px solid #f0f0f0; margin: 12px 0; }
.summary-row { display: flex; justify-content: space-between; align-items: center;
    font-size: 14px; padding: 5px 0; color: #374151; }
.summary-row.grand-total { font-size: 17px; font-weight: 700; color: #111; padding-top: 8px; }
.discount-input-wrap { display: flex; align-items: center; gap: 5px; }
.discount-input { width: 80px; padding: 4px 8px; border: 1px solid #e5e7eb; border-radius: 7px;
    font-size: 13px; text-align: right; background: #f9fafb; color: #111; outline: none; }
.btn-save-full { width: 100%; padding: 11px; background: #111; color: #fff; border: none;
    border-radius: 10px; font-size: 15px; font-weight: 600; cursor: pointer; margin-top: 4px; }
.btn-save-full:hover:not(:disabled) { opacity: .85; }
.btn-save-full:disabled { opacity: .45; cursor: not-allowed; }

.toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
    padding: 10px 20px; border-radius: 10px; font-size: 14px; z-index: 1000; }
.toast-error { background: #fef2f2; color: #991b1b; border: 1px solid #fca5a5; }

@@media (max-width: 768px) {
    .bill-layout { grid-template-columns: 1fr; }
    .summary-card { position: static; }
}
</style>
