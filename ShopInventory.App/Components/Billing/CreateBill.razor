@code {
    [Parameter] public Guid? DraftId { get; set; }

    private OutOfStockWarningDialog _oosDialog = default!;
    private ItemAddedToast _addedToast = default!;

    // ── Draft state ───────────────────────────────────────────────────────
    private bool isDraftMode = false;
    private Guid currentDraftId = Guid.Empty;
    private string currentDraftBillNo = "";

    // ── UI ────────────────────────────────────────────────────────────────
    private bool showManual = false;
    private bool showDropdown = false;
    private bool nameError = false;
    private bool isSaving = false;
    private bool savingAsDraft = false;
    private string errorMessage = "";

    // ── WhatsApp dialog ───────────────────────────────────────────────────
    private bool showWhatsAppDialog = false;
    private bool waUseCustomerPhone = true;
    private string waCustomPhone = "";

    // ── Form ──────────────────────────────────────────────────────────────
    private string customerName = "";
    private string customerPhone = "";
    private string notes = "";
    private string productSearch = "";
    private string manualName = "";
    private decimal manualPrice = 0;
    private decimal discountAmount = 0;
    private PaymentStatus paymentStatus = PaymentStatus.Unpaid;
    private PaymentMethod paymentMethod = PaymentMethod.Cash;

    // ── Data ──────────────────────────────────────────────────────────────
    private List<BillItem> billItems = new();
    private List<ProductDto> searchResults = new();
    private List<ProductDto> allProducts = new();
    private BillItem? _lastAdded = null;
    private Dictionary<string, int> _stockLimits = new();

    private decimal SubTotal => billItems.Sum(i => i.UnitPrice * i.Quantity);
    private decimal GrandTotal => Math.Max(0, SubTotal - discountAmount);

    private string StockKey(Guid productId, Guid? variantId) => $"{productId}_{variantId}";

    protected override async Task OnInitializedAsync()
    {
        allProducts = await ProductService.GetAllAsync();

        // If opened with a DraftId, load that draft for editing
        if (DraftId.HasValue && DraftId.Value != Guid.Empty)
        {
            var draft = await BillService.GetBillByIdAsync(DraftId.Value);
            if (draft is not null)
            {
                isDraftMode = true;
                currentDraftId = draft.Id;
                currentDraftBillNo = draft.BillNo;
                customerName = draft.CustomerName ?? "";
                customerPhone = draft.CustomerPhone ?? "";
                notes = draft.Notes ?? "";
                discountAmount = draft.DiscountAmount;
                paymentStatus = draft.PaymentStatus;
                paymentMethod = draft.PaymentMethod;
                billItems = draft.Items.ToList();

                // Rebuild stock limits from current product data
                foreach (var item in billItems)
                {
                    if (item.ProductId == Guid.Empty) continue;
                    var prod = allProducts.FirstOrDefault(p => p.Id == item.ProductId);
                    if (prod is null) continue;
                    if (item.ProductVariantId.HasValue)
                    {
                        var variant = prod.Variants.FirstOrDefault(v => v.Id == item.ProductVariantId);
                        if (variant is not null)
                            _stockLimits[StockKey(item.ProductId, item.ProductVariantId)] = variant.Quantity;
                    }
                    else
                    {
                        _stockLimits[StockKey(item.ProductId, null)] = prod.Quantity;
                    }
                }
            }
        }
    }

    // ── Search ────────────────────────────────────────────────────────────
    private void SearchProducts(ChangeEventArgs e)
    {
        productSearch = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(productSearch)) { searchResults.Clear(); return; }
        searchResults = allProducts
            .Where(p => p.Name.Contains(productSearch, StringComparison.OrdinalIgnoreCase)
                     || p.Sku.Contains(productSearch, StringComparison.OrdinalIgnoreCase))
            .Take(8).ToList();
        showDropdown = true;
    }

    private void HideDropdown()
        => Task.Delay(150).ContinueWith(_ => { showDropdown = false; InvokeAsync(StateHasChanged); });

    // ── Dropdown clicks ───────────────────────────────────────────────────
    private void HandleProductClick(ProductDto p)
    {
        if (p.Quantity <= 0) { _oosDialog.Show(p.Name); ClearSearch(); return; }
        AddItem(p);
    }

    private void HandleVariantClick(ProductDto p, ProductVariantDto v)
    {
        if (v.Quantity <= 0) { _oosDialog.Show($"{p.Name} – {v.Name}"); ClearSearch(); return; }
        AddFromVariant(p, v);
    }

    // ── Add helpers ───────────────────────────────────────────────────────
    private void AddItem(ProductDto product)
    {
        _stockLimits[StockKey(product.Id, null)] = product.Quantity;
        var existing = billItems.FirstOrDefault(i => i.ProductId == product.Id && i.ProductVariantId == null);
        if (existing != null) { existing.Quantity++; _lastAdded = existing; }
        else
        {
            var item = new BillItem { ProductId = product.Id, ProductName = product.Name, UnitPrice = product.SalePrice, CostPrice = product.CostPrice, Quantity = 1 };
            billItems.Add(item); _lastAdded = item;
        }
        _addedToast.Show(product.Name);
        ClearSearch(); ResetFlash();
    }

    private void AddFromVariant(ProductDto product, ProductVariantDto variant)
    {
        _stockLimits[StockKey(product.Id, variant.Id)] = variant.Quantity;
        var existing = billItems.FirstOrDefault(i => i.ProductId == product.Id && i.ProductVariantId == variant.Id);
        if (existing != null) { existing.Quantity++; _lastAdded = existing; }
        else
        {
            var item = new BillItem { ProductId = product.Id, ProductVariantId = variant.Id, ProductName = product.Name, VariantName = variant.Name, UnitPrice = variant.SalePrice, CostPrice = variant.CostPrice, Quantity = 1 };
            billItems.Add(item); _lastAdded = item;
        }
        _addedToast.Show($"{product.Name} – {variant.Name}");
        ClearSearch(); ResetFlash();
    }

    private void AddManualItem()
    {
        if (string.IsNullOrWhiteSpace(manualName)) { nameError = true; return; }
        if (manualPrice <= 0) return;
        var existing = billItems.FirstOrDefault(i => i.ProductId == Guid.Empty && i.ProductName == manualName.Trim());
        if (existing != null) { existing.Quantity++; _lastAdded = existing; }
        else
        {
            var item = new BillItem { ProductId = Guid.Empty, ProductName = manualName.Trim(), UnitPrice = manualPrice, CostPrice = 0, Quantity = 1 };
            billItems.Add(item); _lastAdded = item;
        }
        _addedToast.Show(manualName.Trim());
        ResetFlash();
        nameError = false; manualName = ""; manualPrice = 0;
    }

    private void ClearSearch() { productSearch = ""; searchResults.Clear(); showDropdown = false; }

    private async void ResetFlash()
    {
        await Task.Delay(2300);
        _lastAdded = null;
        await InvokeAsync(StateHasChanged);
    }

    private void ChangeQty(BillItem item, int delta)
    {
        if (item.ProductId == Guid.Empty)
        {
            item.Quantity = Math.Max(1, item.Quantity + delta);
            return;
        }
        var max = _stockLimits.TryGetValue(StockKey(item.ProductId, item.ProductVariantId), out var s) ? s : 1;
        item.Quantity = Math.Clamp(item.Quantity + delta, 1, max);
    }

    private void UpdatePrice(BillItem item, ChangeEventArgs e)
    { if (decimal.TryParse(e.Value?.ToString(), out var p)) item.UnitPrice = p; }

    // ── Save Draft ────────────────────────────────────────────────────────
    private async Task SaveDraft()
    {
        isSaving = true; savingAsDraft = true;
        try
        {
            var bill = BuildBill();
            bill.Id = currentDraftId; // Guid.Empty = new draft, existing = update
            var saved = await BillService.SaveDraftAsync(bill);
            currentDraftId = saved.Id;
            currentDraftBillNo = saved.BillNo;
            isDraftMode = true;
            errorMessage = "";
        }
        catch (Exception ex) { errorMessage = $"Draft save failed: {ex.Message}"; }
        finally { isSaving = false; savingAsDraft = false; }
    }

    // ── Save / Finalise Bill ──────────────────────────────────────────────
    private async Task SaveBill()
    {
        if (billItems.Count == 0) return;
        isSaving = true; savingAsDraft = false;
        try
        {
            Bill saved;
            if (isDraftMode && currentDraftId != Guid.Empty)
            {
                // Update draft items first, then promote
                var bill = BuildBill();
                bill.Id = currentDraftId;
                await BillService.SaveDraftAsync(bill);
                saved = await BillService.PromoteDraftToSavedAsync(currentDraftId);
            }
            else
            {
                saved = await BillService.CreateBillAsync(BuildBill());
            }
            Navigation.NavigateTo($"/billing/{saved.Id}");
        }
        catch (Exception ex) { errorMessage = $"Error saving bill: {ex.Message}"; isSaving = false; }
    }

    private Bill BuildBill() => new Bill
    {
        CustomerName = string.IsNullOrWhiteSpace(customerName) ? null : customerName,
        CustomerPhone = string.IsNullOrWhiteSpace(customerPhone) ? null : customerPhone,
        Notes = string.IsNullOrWhiteSpace(notes) ? null : notes,
        DiscountAmount = discountAmount,
        PaymentStatus = paymentStatus,
        PaymentMethod = paymentMethod,
        Items = billItems
    };

    // ── WhatsApp ──────────────────────────────────────────────────────────
    public void OpenWhatsAppDialog()
    {
        waUseCustomerPhone = !string.IsNullOrWhiteSpace(customerPhone);
        waCustomPhone = "";
        showWhatsAppDialog = true;
    }

    private void CloseWhatsApp() => showWhatsAppDialog = false;

    private void SendWhatsApp()
    {
        var phone = waUseCustomerPhone ? customerPhone : waCustomPhone;
        if (string.IsNullOrWhiteSpace(phone)) return;

        // Normalise: strip spaces, dashes, brackets; ensure no leading +
        phone = phone.Replace(" ", "").Replace("-", "").Replace("(", "").Replace(")", "");
        if (phone.StartsWith("+")) phone = phone[1..];
        if (phone.StartsWith("0")) phone = "92" + phone[1..]; // Pakistan local → international

        var text = BuildReceiptText();
        var encoded = Uri.EscapeDataString(text);
        var url = $"https://wa.me/{phone}?text={encoded}";

        // Open WhatsApp — works on MAUI via browser launch
        Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(new Uri(url));
        CloseWhatsApp();
    }

    private string BuildReceiptText()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("🧾 *SHEER RABBANI AUTOS*");
        sb.AppendLine("Receipt / Invoice");
        sb.AppendLine("----------------------------");
        if (!string.IsNullOrWhiteSpace(customerName))
            sb.AppendLine($"Customer : {customerName}");
        sb.AppendLine($"Date     : {DateTime.Now:dd MMM yyyy, hh:mm tt}");
        sb.AppendLine("----------------------------");
        foreach (var item in billItems)
        {
            var name = string.IsNullOrEmpty(item.VariantName) ? item.ProductName : $"{item.ProductName} ({item.VariantName})";
            sb.AppendLine($"• {name}  x{item.Quantity}  Rs.{(item.UnitPrice * item.Quantity):N0}");
        }
        sb.AppendLine("----------------------------");
        sb.AppendLine($"Subtotal : Rs. {SubTotal:N0}");
        if (discountAmount > 0)
            sb.AppendLine($"Discount : Rs. {discountAmount:N0}");
        sb.AppendLine($"*Total   : Rs. {GrandTotal:N0}*");
        sb.AppendLine("----------------------------");
        sb.AppendLine($"Payment  : {paymentMethod}");
        sb.AppendLine($"Status   : {paymentStatus}");
        sb.AppendLine("Thank you for your business! 🙏");
        return sb.ToString();
    }

    private void GoBack() => Navigation.NavigateTo("/billing");
}
