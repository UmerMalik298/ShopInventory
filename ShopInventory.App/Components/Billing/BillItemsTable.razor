<div class="bill-card">
    <h4 class="bill-card-title">Bill Items</h4>

    @if (Items.Count == 0)
    {
        <p class="empty-text">No items added yet.</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="table custom-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Variant</th>
                        <th>Qty</th>
                        <th>Unit Price</th>
                        <th>Total</th>
                        <th>Remove</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@(string.IsNullOrWhiteSpace(item.VariantName) ? "-" : item.VariantName)</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitPrice.ToString("F2")</td>
                            <td>@item.LineTotal.ToString("F2")</td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => OnRemoveItem.InvokeAsync(item.RowId)">
                                    Remove
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    [Parameter] public List<dynamic> Items { get; set; } = new();
    [Parameter] public EventCallback<Guid> OnRemoveItem { get; set; }
}