@page "/billing"
@using ShopInventory.Domain.Entities.Enums
@using ShopInventory.Domain.Entities.Billing
@using ShopInventory.Application.Interfaces
@using ShopInventory.Application.DTOs
@using ShopInventory.App.Components.Common
@inject IBillService BillService
@inject NavigationManager Navigation

<div class="billing-page">
    <div class="page-header">
        <div class="header-left">
            <h2>Bills</h2>
            <span class="total-count">@_paged.TotalCount total</span>
        </div>
        <button class="btn-create" @onclick="CreateNewBill">
            <span class="icon">+</span> New Bill
        </button>
    </div>

    <!-- Search & Filter Bar -->
    <div class="filter-bar">
        <div class="search-wrap">
            <span class="search-icon">&#x1F50D;</span>
            <input type="text" placeholder="Search by bill no or customer..."
                   value="@_search" @oninput="OnSearchInput" />
        </div>
        <div class="status-filters">
            <button class="filter-pill @(_activeFilter == "all" ? "active" : "")" @onclick="@(() => SetFilter("all"))">All</button>
            <button class="filter-pill unpaid @(_activeFilter == "unpaid" ? "active" : "")" @onclick="@(() => SetFilter("unpaid"))">Unpaid</button>
            <button class="filter-pill paid   @(_activeFilter == "paid" ? "active" : "")" @onclick="@(() => SetFilter("paid"))">Paid</button>
            <button class="filter-pill partial @(_activeFilter == "partial" ? "active" : "")" @onclick="@(() => SetFilter("partial"))">Partial</button>
            <button class="filter-pill draft  @(_activeFilter == "draft" ? "active" : "")" @onclick="@(() => SetFilter("draft"))">Drafts</button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading bills...</p>
        </div>
    }
    else if (_paged.Items.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">&#x1F9FE;</div>
            <h3>No bills found</h3>
            <p>
                @(string.IsNullOrWhiteSpace(_search) && _activeFilter == "all"
                            ? "Create your first bill to get started"
                            : "No bills match your search or filter")
        </p>
        @if (string.IsNullOrWhiteSpace(_search) && _activeFilter == "all")
            {
                <button class="btn-create" @onclick="CreateNewBill">+ New Bill</button>
            }
        </div>
    }
    else
    {
        <div class="bills-list">
            @foreach (var bill in _paged.Items)
            {
                <div class="bill-card @(bill.IsDraft ? "draft-card" : "")"
                     @onclick="@(() => OpenBill(bill.Id))">
                    <div class="bill-main">
                        <div class="bill-info">
                            <div class="bill-no-row">
                                <span class="bill-no">@bill.BillNo</span>
                                @if (bill.IsDraft)
                                {
                                    <span class="draft-badge">Draft</span>
                                }
                            </div>
                            <span class="customer-name">
                                @(string.IsNullOrEmpty(bill.CustomerName) ? "Walk-in Customer" : bill.CustomerName)
                            </span>
                            <span class="bill-date">
                                @bill.BilledAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")
                            </span>
                        </div>
                        <div class="bill-right">
                            <span class="bill-amount">Rs. @bill.TotalAmount.ToString("N0")</span>
                            @if (!bill.IsDraft)
                            {
                                <span class="status-badge @GetStatusClass(bill.PaymentStatus)">
                                    @bill.PaymentStatus
                                </span>
                            }
                            <span class="items-count">@bill.ItemCount item(s)</span>
                            <button class="btn-edit-bill"
                                    @onclick:stopPropagation="true"
                                    @onclick="@(() => EditBill(bill.Id))"
                                    title="@(bill.IsDraft ? "Continue editing draft" : "Edit bill")">
                                ✏️
                            </button>
                            <button class="btn-delete-bill"
                                    @onclick:stopPropagation="true"
                                    @onclick="@(() => AskDeleteBill(bill))">
                                ✕
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (_paged.TotalPages > 1)
        {
            <div class="pagination-bar">
                <button class="pg-btn" disabled="@(!_paged.HasPrev)"
                        @onclick="@(() => GoToPage(_page - 1))">
                    &#8592;
                </button>
                @for (int i = StartPage; i <= EndPage; i++)
                {
                    var pageNum = i;
                    <button class="pg-btn @(pageNum == _page ? "pg-active" : "")"
                            @onclick="@(() => GoToPage(pageNum))">
                        @pageNum
                    </button>
                }
                <button class="pg-btn" disabled="@(!_paged.HasNext)"
                        @onclick="@(() => GoToPage(_page + 1))">
                    &#8594;
                </button>
                <span class="pg-info">@_paged.TotalCount bills</span>
            </div>
        }
    }
</div>

<ConfirmDialog IsOpen="_showDeleteConfirm"
               Title="Delete Bill"
               Message="@($"Are you sure you want to delete bill \"{_billToDelete?.BillNo}\"? This cannot be undone.")"
               ConfirmText="Delete"
               CancelText="Cancel"
               IsDanger="true"
               OnConfirm="ConfirmDeleteBill"
               OnCancel="CancelDeleteBill" />

@code {
    // ── FIX: use a lightweight DTO instead of the full Bill entity ─────────
    // The full Bill entity eager-loads BillItems — unnecessary for a list view.
    // BillListDto only contains what the list UI actually needs.
    private PagedResult<BillListDto> _paged = new() { Items = new() };

    private string _search = "";
    private string _activeFilter = "all";
    private int _page = 1;
    private const int PageSize = 10;
    private bool _loading = true;

    private System.Timers.Timer? _debounce;

    private int StartPage => Math.Max(1, _page - 2);
    private int EndPage => Math.Min(_paged.TotalPages, StartPage + 4);

    private bool _showDeleteConfirm = false;
    private BillListDto? _billToDelete = null;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        _paged = await BillService.GetPagedBillsAsync(_search, _activeFilter, _page, PageSize);
        _loading = false;
        StateHasChanged();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        _page = 1;
        _debounce?.Stop();
        _debounce?.Dispose();
        _debounce = new System.Timers.Timer(300);
        _debounce.Elapsed += async (_, _) =>
        {
            _debounce?.Dispose();
            await InvokeAsync(LoadAsync);
        };
        _debounce.AutoReset = false;
        _debounce.Start();
    }

    private async Task SetFilter(string filter) { _activeFilter = filter; _page = 1; await LoadAsync(); }
    private async Task GoToPage(int page) { _page = page; await LoadAsync(); }

    private string GetStatusClass(PaymentStatus status) => status switch
    {
        PaymentStatus.Paid => "badge-paid",
        PaymentStatus.Unpaid => "badge-unpaid",
        PaymentStatus.PartiallyPaid => "badge-partial",
        _ => ""
    };

    private void CreateNewBill() => Navigation.NavigateTo("/billing/create");
    private void OpenBill(Guid id) => Navigation.NavigateTo($"/billing/{id}");
    private void EditBill(Guid id) => Navigation.NavigateTo($"/billing/edit/{id}");

    private void AskDeleteBill(BillListDto bill)
    {
        _billToDelete = bill;
        _showDeleteConfirm = true;
    }

    private async Task ConfirmDeleteBill()
    {
        _showDeleteConfirm = false;
        if (_billToDelete != null)
        {
            await BillService.DeleteBillAsync(_billToDelete.Id);
            await LoadAsync();
        }
        _billToDelete = null;
    }

    private void CancelDeleteBill()
    {
        _showDeleteConfirm = false;
        _billToDelete = null;
    }
}
