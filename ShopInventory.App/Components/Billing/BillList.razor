@page "/billing"
@using ShopInventory.Domain.Entities.Enums
@using ShopInventory.Domain.Entities.Sales
@using ShopInventory.Domain.Entities.Billing
@using ShopInventory.Application.Interfaces
@inject IBillService BillService
@inject NavigationManager Navigation

<div class="billing-page">
    <div class="page-header">
        <div class="header-left">
            <h2>Bills</h2>
            <span class="total-count">@bills.Count total</span>
        </div>
        <button class="btn-create" @onclick="CreateNewBill">
            <span class="icon">+</span> New Bill
        </button>
    </div>

    <!-- Search & Filter Bar -->
    <div class="filter-bar">
        <div class="search-wrap">
            <span class="search-icon">&#x1F50D;</span>
            <input type="text" placeholder="Search by bill no or customer..."
                   value="@searchTerm" @oninput="FilterBills" />
        </div>
        <div class="status-filters">
            <button class="filter-pill @(activeFilter == "all" ? "active" : "")"
                    @onclick="@(() => SetFilter("all"))">All</button>
            <button class="filter-pill unpaid @(activeFilter == "unpaid" ? "active" : "")"
                    @onclick="@(() => SetFilter("unpaid"))">Unpaid</button>
            <button class="filter-pill paid @(activeFilter == "paid" ? "active" : "")"
                    @onclick="@(() => SetFilter("paid"))">Paid</button>
            <button class="filter-pill partial @(activeFilter == "partial" ? "active" : "")"
                    @onclick="@(() => SetFilter("partial"))">Partial</button>
        </div>
    </div>

    <!-- Bills List -->
    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading bills...</p>
        </div>
    }
    else if (filteredBills.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">&#x1F9FE;</div>
            <h3>No bills found</h3>
            <p>Create your first bill to get started</p>
            <button class="btn-create" @onclick="CreateNewBill">+ New Bill</button>
        </div>
    }
    else
    {
        <div class="bills-list">
            @foreach (var bill in filteredBills)
            {
                <div class="bill-card" @onclick="@(() => OpenBill(bill.Id))">
                    <div class="bill-main">
                        <div class="bill-info">
                            <span class="bill-no">@bill.BillNo</span>
                            <span class="customer-name">@(string.IsNullOrEmpty(bill.CustomerName) ? "Walk-in Customer" : bill.CustomerName)</span>
                            <span class="bill-date">@bill.BilledAt.ToString("dd MMM yyyy, hh:mm tt")</span>
                        </div>
                        <div class="bill-right">
                            <span class="bill-amount">Rs. @bill.TotalAmount.ToString("N0")</span>
                            <span class="status-badge @GetStatusClass(bill.PaymentStatus)">
                                @bill.PaymentStatus
                            </span>
                            <span class="items-count">@bill.Items.Count item(s)</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Bill> bills = new();
    private List<Bill> filteredBills = new();
    private string searchTerm = "";
    private string activeFilter = "all";
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadBills();
    }

    private async Task LoadBills()
    {
        isLoading = true;
        bills = await BillService.GetAllBillsAsync();
        ApplyFilter();
        isLoading = false;
    }

    private void FilterBills(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        ApplyFilter();
    }

    private void SetFilter(string filter)
    {
        activeFilter = filter;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        var query = bills.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
            query = query.Where(b =>
                b.BillNo.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (b.CustomerName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

        if (activeFilter == "unpaid")
            query = query.Where(b => b.PaymentStatus == PaymentStatus.Unpaid);
        else if (activeFilter == "paid")
            query = query.Where(b => b.PaymentStatus == PaymentStatus.Paid);
        else if (activeFilter == "partial")
            query = query.Where(b => b.PaymentStatus == PaymentStatus.PartiallyPaid);

        filteredBills = query.ToList();
    }

    private string GetStatusClass(PaymentStatus status) => status switch
    {
        PaymentStatus.Paid => "badge-paid",
        PaymentStatus.Unpaid => "badge-unpaid",
        PaymentStatus.PartiallyPaid => "badge-partial",
        _ => ""
    };

    private void CreateNewBill() => Navigation.NavigateTo("/billing/create");
    private void OpenBill(Guid id) => Navigation.NavigateTo($"/billing/{id}");
}

<style>
.billing-page { padding: 1.25rem; max-width: 900px; margin: 0 auto; }

.page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
.page-header h2 { font-size: 20px; font-weight: 600; color: var(--text-primary, #111); margin: 0; }
.total-count { margin-left: 8px; font-size: 13px; color: var(--text-muted, #888); }
.header-left { display: flex; align-items: baseline; gap: 4px; }

.btn-create { display: flex; align-items: center; gap: 6px; background: #111; color: #fff;
    border: none; border-radius: 10px; padding: 9px 18px; font-size: 14px; font-weight: 500;
    cursor: pointer; transition: opacity .15s; }
.btn-create:hover { opacity: .85; }
.btn-create .icon { font-size: 18px; line-height: 1; }

.filter-bar { display: flex; gap: 12px; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; }
.search-wrap { position: relative; flex: 1; min-width: 200px; }
.search-wrap input { width: 100%; padding: 9px 12px 9px 36px; border-radius: 10px;
    border: 1px solid #e5e7eb; background: #f9fafb; font-size: 14px; outline: none; color: #111; }
.search-icon { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); font-size: 14px; color: #999; }

.status-filters { display: flex; gap: 6px; }
.filter-pill { padding: 6px 14px; border-radius: 20px; border: 1px solid #e5e7eb;
    background: transparent; font-size: 13px; cursor: pointer; color: #555; transition: all .15s; }
.filter-pill.active, .filter-pill:hover { background: #111; color: #fff; border-color: #111; }
.filter-pill.unpaid.active { background: #f59e0b; border-color: #f59e0b; color: #fff; }
.filter-pill.paid.active { background: #10b981; border-color: #10b981; color: #fff; }
.filter-pill.partial.active { background: #3b82f6; border-color: #3b82f6; color: #fff; }

.bills-list { display: flex; flex-direction: column; gap: 8px; }
.bill-card { background: #fff; border: 1px solid #f0f0f0; border-radius: 12px;
    padding: 14px 16px; cursor: pointer; transition: box-shadow .15s, border-color .15s; }
.bill-card:hover { border-color: #d1d5db; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
.bill-main { display: flex; justify-content: space-between; align-items: center; gap: 12px; }
.bill-info { display: flex; flex-direction: column; gap: 2px; }
.bill-no { font-size: 13px; font-weight: 600; color: #111; font-family: monospace; }
.customer-name { font-size: 14px; color: #374151; }
.bill-date { font-size: 12px; color: #9ca3af; }
.bill-right { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
.bill-amount { font-size: 16px; font-weight: 700; color: #111; }
.items-count { font-size: 11px; color: #9ca3af; }

.status-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
.badge-paid { background: #d1fae5; color: #065f46; }
.badge-unpaid { background: #fef3c7; color: #92400e; }
.badge-partial { background: #dbeafe; color: #1e40af; }

.empty-state { text-align: center; padding: 3rem 1rem; }
.empty-icon { font-size: 48px; margin-bottom: 12px; }
.empty-state h3 { font-size: 18px; font-weight: 600; color: #111; margin: 0 0 6px; }
.empty-state p { color: #6b7280; font-size: 14px; margin-bottom: 16px; }

.loading-state { display: flex; flex-direction: column; align-items: center; padding: 3rem; gap: 12px; color: #999; }
.spinner { width: 28px; height: 28px; border: 3px solid #e5e7eb; border-top-color: #111;
    border-radius: 50%; animation: spin .7s linear infinite; }
@@keyframes spin { to { transform: rotate(360deg); } }
</style>
