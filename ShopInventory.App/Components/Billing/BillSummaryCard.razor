<div class="bill-card">
    <h4 class="bill-card-title">Bill Summary</h4>

    <div class="summary-grid">
        <div>
            <label>Sub Total</label>
            <div class="summary-value">@SubTotal.ToString("F2")</div>
        </div>

        <div>
            <label>Discount</label>
            <input class="form-control" type="number" step="0.01" value="@DiscountAmount" @oninput="HandleDiscountChanged" />
        </div>

        <div>
            <label>Tax</label>
            <input class="form-control" type="number" step="0.01" value="@TaxAmount" @oninput="HandleTaxChanged" />
        </div>

        <div>
            <label>Grand Total</label>
            <div class="summary-value strong">@GrandTotal.ToString("F2")</div>
        </div>
    </div>

    <div class="action-row">
        <button class="btn btn-primary" @onclick="OnSaveBill.InvokeAsync">Save Bill</button>
        <button class="btn btn-outline-secondary" @onclick="OnClearBill.InvokeAsync">Clear</button>
    </div>
</div>

@code {
    [Parameter] public decimal SubTotal { get; set; }
    [Parameter] public decimal DiscountAmount { get; set; }
    [Parameter] public decimal TaxAmount { get; set; }
    [Parameter] public decimal GrandTotal { get; set; }

    [Parameter] public EventCallback<decimal> OnDiscountChanged { get; set; }
    [Parameter] public EventCallback<decimal> OnTaxChanged { get; set; }
    [Parameter] public EventCallback OnSaveBill { get; set; }
    [Parameter] public EventCallback OnClearBill { get; set; }

    private async Task HandleDiscountChanged(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var value))
            await OnDiscountChanged.InvokeAsync(value);
    }

    private async Task HandleTaxChanged(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var value))
            await OnTaxChanged.InvokeAsync(value);
    }
}