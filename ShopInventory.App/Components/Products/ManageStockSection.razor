@using ShopInventory.Application.DTOs
@using ShopInventory.Application.Interfaces
@using Microsoft.Maui.Storage
@inject IProductService ProductService

<div class="tab-card">
    <h5 class="mb-4">Manage Stock</h5>

    <!-- Search + Filters -->
    <div class="filter-bar">
        <input class="form-control search-box"
               placeholder="Search by name or SKU..."
               value="@_search"
               @oninput="OnSearchInput" />

        <div class="filter-row">
            <div class="filter-group">
                <label class="filter-label">Category</label>
                <select class="filter-select" value="@_categoryFilter" @onchange="OnCategoryChange">
                    <option value="">All Categories</option>
                    @foreach (var cat in _categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>

            <div class="filter-group">
                <label class="filter-label">Stock</label>
                <select class="filter-select" value="@_stockFilter" @onchange="OnStockFilterChange">
                    <option value="">All</option>
                    <option value="instock">In Stock</option>
                    <option value="lowstock">Low Stock (&#8804;10)</option>
                    <option value="outofstock">Out of Stock</option>
                </select>
            </div>

            @if (HasActiveFilters)
            {
                <button class="filter-reset-btn" @onclick="ResetFilters">&#10005; Clear</button>
            }
        </div>
    </div>

    <!-- Active Pills -->
    @if (HasActiveFilters)
    {
        <div class="filter-pills">
            @if (!string.IsNullOrWhiteSpace(_categoryFilter))
            {
                <span class="filter-pill">
                    &#128193; @_categoryFilter
                    <button @onclick="RemoveCategoryFilter">&#215;</button>
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(_stockFilter))
            {
                <span class="filter-pill">
                    &#128230; @GetStockLabel(_stockFilter)
                    <button @onclick="RemoveStockFilter">&#215;</button>
                </span>
            }
        </div>
    }

    @if (_loading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading products...</p>
        </div>
    }
    else if (_paged.Items.Count == 0)
    {
        <p class="empty-text">
            @(string.IsNullOrWhiteSpace(_search) && !HasActiveFilters
                    ? "No products available."
                    : "No results found. Try adjusting your filters.")
    </p>
        }
    else
    {
        <div class="table-wrap">
            <table class="table custom-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>SKU</th>
                        <th>Category</th>
                        <th>Qty</th>
                        <th>Stock</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in _paged.Items)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(product.ImagePath))
                                {
                                    <img src="@GetImageSource(product.ImagePath)"
                                         class="product-thumb" alt="@product.Name" />
                                }
                                else
                                {
                                    <div class="no-image-thumb" title="No image">
                                        <span>&#128247;</span>
                                    </div>
                                }
                            </td>
                            <td>@product.Name</td>
                            <td><span class="sku-pill">@product.Sku</span></td>
                            <td>@(product.Category ?? "—")</td>
                            <td>@product.Quantity</td>
                            <td>
                                <div class="stock-actions">
                                    <button class="btn btn-sm btn-success"
                                            @onclick="() => AdjustStock(product.Id, +1)">
                                        +
                                    </button>
                                    <button class="btn btn-sm btn-danger"
                                            @onclick="() => AdjustStock(product.Id, -1)">
                                        −
                                    </button>
                                </div>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => OpenEdit(product)">
                                        &#9999;&#65039; Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => AskDelete(product)">
                                        &#128465; Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_paged.TotalPages > 1)
        {
            <div class="pagination-bar">
                <button class="pg-btn" disabled="@(!_paged.HasPrev)"
                        @onclick="@(() => GoToPage(_page - 1))">
                    &#8592;
                </button>

                @for (int i = StartPage; i <= EndPage; i++)
                {
                    var pageNum = i;
                    <button class="pg-btn @(pageNum == _page ? "pg-active" : "")"
                            @onclick="@(() => GoToPage(pageNum))">
                        @pageNum
                    </button>
                }

                <button class="pg-btn" disabled="@(!_paged.HasNext)"
                        @onclick="@(() => GoToPage(_page + 1))">
                    &#8594;
                </button>
                <span class="pg-info">@_paged.TotalCount products</span>
            </div>
        }
    }
</div>

<!-- Edit Modal -->
@if (_showEditModal && _editingProduct != null)
{
    <div class="edit-overlay" @onclick="CloseEdit">
        <div class="edit-box" @onclick:stopPropagation="true">
            <div class="edit-header">
                <h3>Edit Product</h3>
                <button class="cd-close" @onclick="CloseEdit">&#10005;</button>
            </div>
            <div class="edit-body">
                <div class="edit-image-section">
                    @if (!string.IsNullOrWhiteSpace(_editImagePath))
                    {
                        <img src="@GetImageSource(_editImagePath)"
                             class="edit-image-preview" alt="Product image" />
                    }
                    else
                    {
                        <div class="edit-no-image">
                            <span>&#128247;</span>
                            <p>No image</p>
                        </div>
                    }
                    <button class="btn btn-sm btn-outline-secondary mt-2"
                            @onclick="PickEditImageAsync">
                        &#128247; Upload Image
                    </button>
                </div>

                <div class="edit-field">
                    <label>Name</label>
                    <input type="text" @bind="_editName" placeholder="Product name" />
                </div>
                <div class="edit-field">
                    <label>SKU</label>
                    <input type="text" @bind="_editSku" placeholder="SKU" />
                </div>
                <div class="edit-row">
                    <div class="edit-field">
                        <label>Quantity</label>
                        <input type="number" @bind="_editQuantity" min="0" />
                    </div>
                    <div class="edit-field">
                        <label>Sale Price</label>
                        <input type="number" @bind="_editSalePrice" min="0" />
                    </div>
                    <div class="edit-field">
                        <label>Cost Price</label>
                        <input type="number" @bind="_editCostPrice" min="0" />
                    </div>
                </div>
                <div class="edit-row">
                    <div class="edit-field">
                        <label>Category</label>
                        <input type="text" @bind="_editCategory" placeholder="Category" />
                    </div>
                    <div class="edit-field">
                        <label>Unit</label>
                        <input type="text" @bind="_editUnit" placeholder="e.g. pcs, kg" />
                    </div>
                </div>
            </div>
            <div class="edit-footer">
                <button class="cd-btn cd-btn-light" @onclick="CloseEdit">Cancel</button>
                <button class="cd-btn cd-btn-primary" @onclick="ConfirmEdit">Save Changes</button>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation -->
<ConfirmDialog IsOpen="_showDeleteConfirm"
               Title="Delete Product"
               Message="@($"Are you sure you want to delete \"{_productToDelete?.Name}\"? This cannot be undone.")"
               ConfirmText="Delete"
               CancelText="Cancel"
               IsDanger="true"
               OnConfirm="ConfirmDelete"
               OnCancel="CancelDelete" />

@code {
    [Parameter] public EventCallback<Guid> OnIncreaseQuantity { get; set; }
    [Parameter] public EventCallback<Guid> OnDecreaseQuantity { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteProduct { get; set; }
    [Parameter] public EventCallback<ProductDto> OnEditProduct { get; set; }

    // ── Paged result from DB ───────────────────────────────────────────────
    private PagedResult<ProductDto> _paged =
        new() { Items = new(), PageSize = 10, Page = 1 };

    // ── Filter / search state ──────────────────────────────────────────────
    private string _search = "";
    private int _page = 1;
    private const int PageSize = 10;
    private bool _loading = false;
    private string _categoryFilter = "";
    private string _stockFilter = "";
    private List<string> _categories = new();

    private System.Timers.Timer? _debounce;
    private readonly Dictionary<string, string> _imageCache = new();

    // ── Edit modal state ───────────────────────────────────────────────────
    private bool _showEditModal = false;
    private ProductDto? _editingProduct = null;
    private string _editName = "";
    private string _editSku = "";
    private int _editQuantity = 0;
    private decimal _editSalePrice = 0;
    private decimal _editCostPrice = 0;
    private string _editCategory = "";
    private string _editUnit = "";
    private string _editImagePath = "";

    // ── Delete confirm state ───────────────────────────────────────────────
    private bool _showDeleteConfirm = false;
    private ProductDto? _productToDelete = null;

    // ── Computed ───────────────────────────────────────────────────────────
    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_categoryFilter) ||
        !string.IsNullOrWhiteSpace(_stockFilter);

    private int StartPage => Math.Max(1, _page - 2);
    private int EndPage => Math.Min(_paged.TotalPages, StartPage + 4);

    // ── Lifecycle ──────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadCategoriesAsync();
        await LoadAsync();
    }

    public async Task RefreshAsync()
    {
        _page = 1;
        await LoadCategoriesAsync();
        await LoadAsync();
    }

    // ── Data loading ───────────────────────────────────────────────────────
    // FIX: one cheap DISTINCT query instead of loading all products
    private async Task LoadCategoriesAsync()
    {
        _categories = await ProductService.GetDistinctCategoriesAsync();
    }

    // FIX: SQLite does all the work — only 10 rows ever come back
    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        _paged = await ProductService.GetPagedAsync(
            search: _search,
            page: _page,
            pageSize: PageSize,
            category: _categoryFilter,
            stockFilter: _stockFilter
        );

        // Clamp page if filters reduced the total
        if (_page > _paged.TotalPages && _paged.TotalPages > 0)
        {
            _page = _paged.TotalPages;
            _paged = await ProductService.GetPagedAsync(
                search: _search,
                page: _page,
                pageSize: PageSize,
                category: _categoryFilter,
                stockFilter: _stockFilter
            );
        }

        _loading = false;
        StateHasChanged();
    }

    // ── Event handlers ─────────────────────────────────────────────────────
    private void OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        _page = 1;
        TriggerDebounce();
    }

    private async Task OnCategoryChange(ChangeEventArgs e)
    {
        _categoryFilter = e.Value?.ToString() ?? "";
        _page = 1;
        await LoadAsync();
    }

    private async Task OnStockFilterChange(ChangeEventArgs e)
    {
        _stockFilter = e.Value?.ToString() ?? "";
        _page = 1;
        await LoadAsync();
    }

    private async Task ResetFilters()
    {
        _categoryFilter = "";
        _stockFilter = "";
        _page = 1;
        await LoadAsync();
    }

    private async Task RemoveCategoryFilter() { _categoryFilter = ""; _page = 1; await LoadAsync(); }
    private async Task RemoveStockFilter() { _stockFilter = ""; _page = 1; await LoadAsync(); }

    private async Task GoToPage(int page) { _page = page; await LoadAsync(); }

    // ── Debounce for search ────────────────────────────────────────────────
    private void TriggerDebounce()
    {
        _debounce?.Stop();
        _debounce?.Dispose();
        _debounce = new System.Timers.Timer(300);
        _debounce.Elapsed += async (_, _) =>
        {
            _debounce?.Dispose();
            await InvokeAsync(LoadAsync);
        };
        _debounce.AutoReset = false;
        _debounce.Start();
    }

    // ── Stock adjustment ───────────────────────────────────────────────────
    // FIX: update the DB directly then reload just this page — no full refresh
    private async Task AdjustStock(Guid id, int delta)
    {
        if (delta > 0) await OnIncreaseQuantity.InvokeAsync(id);
        else await OnDecreaseQuantity.InvokeAsync(id);

        // Optimistic local update so the number changes instantly
        var item = _paged.Items.FirstOrDefault(p => p.Id == id);
        if (item != null)
        {
            item.Quantity = Math.Max(0, item.Quantity + delta);
            StateHasChanged();
        }
    }

    // ── Delete ─────────────────────────────────────────────────────────────
    private void AskDelete(ProductDto product)
    {
        _productToDelete = product;
        _showDeleteConfirm = true;
    }

    private async Task ConfirmDelete()
    {
        _showDeleteConfirm = false;
        if (_productToDelete != null)
        {
            await OnDeleteProduct.InvokeAsync(_productToDelete.Id);
            await LoadAsync();   // reload current page after deletion
        }
        _productToDelete = null;
    }

    private void CancelDelete()
    {
        _showDeleteConfirm = false;
        _productToDelete = null;
    }

    // ── Edit modal ─────────────────────────────────────────────────────────
    private void OpenEdit(ProductDto product)
    {
        _editingProduct = product;
        _editName = product.Name;
        _editSku = product.Sku;
        _editQuantity = product.Quantity;
        _editSalePrice = product.SalePrice;
        _editCostPrice = product.CostPrice;
        _editCategory = product.Category ?? "";
        _editUnit = product.Unit ?? "";
        _editImagePath = product.ImagePath ?? "";
        _showEditModal = true;
    }

    private void CloseEdit()
    {
        _showEditModal = false;
        _editingProduct = null;
    }

    private async Task PickEditImageAsync()
    {
        var file = await FilePicker.Default.PickAsync(new PickOptions
        {
            PickerTitle = "Select product image",
            FileTypes = FilePickerFileType.Images
        });
        if (file is null) return;

        var extension = Path.GetExtension(file.FileName);
        var fileName = $"{Guid.NewGuid()}{extension}";
        var localPath = Path.Combine(FileSystem.AppDataDirectory, fileName);

        await using (var src = await file.OpenReadAsync())
        await using (var dest = File.Create(localPath))
            await src.CopyToAsync(dest);

        _imageCache.Remove(localPath);
        _editImagePath = localPath;
        StateHasChanged();
    }

    private async Task ConfirmEdit()
    {
        if (_editingProduct == null) return;

        var updated = new ProductDto
        {
            Id = _editingProduct.Id,
            Name = _editName.Trim(),
            Sku = _editSku.Trim(),
            Quantity = _editQuantity,
            SalePrice = _editSalePrice,
            CostPrice = _editCostPrice,
            Category = _editCategory.Trim(),
            Unit = _editUnit.Trim(),
            ImagePath = _editImagePath
        };

        await OnEditProduct.InvokeAsync(updated);

        // Optimistic local update so the row reflects changes instantly
        var local = _paged.Items.FirstOrDefault(p => p.Id == updated.Id);
        if (local != null)
        {
            local.Name = updated.Name;
            local.Sku = updated.Sku;
            local.Quantity = updated.Quantity;
            local.SalePrice = updated.SalePrice;
            local.CostPrice = updated.CostPrice;
            local.Category = updated.Category;
            local.Unit = updated.Unit;
            local.ImagePath = updated.ImagePath;
        }

        CloseEdit();
        StateHasChanged();
    }

    // ── Image cache ────────────────────────────────────────────────────────
    private string GetImageSource(string? path)
    {
        if (string.IsNullOrWhiteSpace(path) || !File.Exists(path)) return "";
        if (_imageCache.TryGetValue(path, out var cached)) return cached;

        try
        {
            using var stream = new FileStream(
                path, FileMode.Open, FileAccess.Read, FileShare.ReadWrite);
            using var ms = new MemoryStream();
            stream.CopyTo(ms);

            var mime = Path.GetExtension(path).ToLowerInvariant() switch
            {
                ".png" => "image/png",
                ".jpg" or ".jpeg" => "image/jpeg",
                ".webp" => "image/webp",
                ".gif" => "image/gif",
                _ => "image/jpeg"
            };

            var result = $"data:{mime};base64,{Convert.ToBase64String(ms.ToArray())}";
            _imageCache[path] = result;
            return result;
        }
        catch { return ""; }
    }

    // ── Labels ─────────────────────────────────────────────────────────────
    private string GetStockLabel(string s) => s switch
    {
        "instock" => "In Stock",
        "lowstock" => "Low Stock",
        "outofstock" => "Out of Stock",
        _ => ""
    };
}
