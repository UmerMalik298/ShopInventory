@using ShopInventory.Application.DTOs
@using ShopInventory.Application.Interfaces
@using Microsoft.Maui.Storage
@inject IProductService ProductService

<div class="tab-card">
    <h5 class="mb-4">Manage Stock</h5>

    <!-- Search + Filters -->
    <div class="filter-bar">
        <input class="form-control search-box"
               placeholder="Search by name or SKU..."
               value="@_search"
               @oninput="OnSearchInput" />

        <div class="filter-row">
            <div class="filter-group">
                <label class="filter-label">Category</label>
                <select class="filter-select" value="@_categoryFilter" @onchange="OnCategoryChange">
                    <option value="">All Categories</option>
                    @foreach (var cat in _categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>

            <div class="filter-group">
                <label class="filter-label">Stock</label>
                <select class="filter-select" value="@_stockFilter" @onchange="OnStockFilterChange">
                    <option value="">All</option>
                    <option value="instock">In Stock</option>
                    <option value="lowstock">Low Stock (&#8804;10)</option>
                    <option value="outofstock">Out of Stock</option>
                </select>
            </div>

            @if (HasActiveFilters)
            {
                <button class="filter-reset-btn" @onclick="ResetFilters">&#10005; Clear</button>
            }
        </div>
    </div>

    <!-- Active Pills -->
    @if (HasActiveFilters)
    {
        <div class="filter-pills">
            @if (!string.IsNullOrWhiteSpace(_categoryFilter))
            {
                <span class="filter-pill">
                    &#128193; @_categoryFilter
                    <button @onclick="RemoveCategoryFilter">&#215;</button>
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(_stockFilter))
            {
                <span class="filter-pill">
                    &#128230; @GetStockLabel(_stockFilter)
                    <button @onclick="RemoveStockFilter">&#215;</button>
                </span>
            }
        </div>
    }

    @if (_loading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading products...</p>
        </div>
    }
    else if (_filtered.Count == 0)
    {
        <p class="empty-text">
            @(string.IsNullOrWhiteSpace(_search) && !HasActiveFilters
                    ? "No products available."
                    : "No results found. Try adjusting your filters.")
    </p>
        }
    else
    {
        <div class="table-wrap">
            <table class="table custom-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>SKU</th>
                        <th>Category</th>
                        <th>Qty</th>
                        <th>Stock</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in _paginated)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(product.ImagePath))
                                {
                                    <img src="@GetImageSource(product.ImagePath)"
                                         class="product-thumb" alt="@product.Name" />
                                }
                                else
                                {
                                    <div class="no-image-thumb" title="No image">
                                        <span>&#128247;</span>
                                    </div>
                                }
                            </td>
                            <td>@product.Name</td>
                            <td><span class="sku-pill">@product.Sku</span></td>
                            <td>@(product.Category ?? "—")</td>
                            <td>@product.Quantity</td>
                            <td>
                                <div class="stock-actions">
                                    <button class="btn btn-sm btn-success"
                                            @onclick="() => AdjustStock(product.Id, +1)">
                                        +
                                    </button>
                                    <button class="btn btn-sm btn-danger"
                                            @onclick="() => AdjustStock(product.Id, -1)">
                                        −
                                    </button>
                                </div>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => OpenEdit(product)">
                                        &#9999;&#65039; Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => AskDelete(product)">
                                        &#128465; Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_totalPages > 1)
        {
            <div class="pagination-bar">
                <button class="pg-btn" disabled="@(_page <= 1)"
                        @onclick="@(() => GoToPage(_page - 1))">
                    &#8592;
                </button>

                @for (int i = StartPage; i <= EndPage; i++)
                {
                    var pageNum = i;
                    <button class="pg-btn @(pageNum == _page ? "pg-active" : "")"
                            @onclick="@(() => GoToPage(pageNum))">
                        @pageNum
                    </button>
                }

                <button class="pg-btn" disabled="@(_page >= _totalPages)"
                        @onclick="@(() => GoToPage(_page + 1))">
                    &#8594;
                </button>
                <span class="pg-info">@_filtered.Count products</span>
            </div>
        }
    }
</div>

<!-- Edit Modal -->
@if (showEditModal && editingProduct != null)
{
    <div class="edit-overlay" @onclick="CloseEdit">
        <div class="edit-box" @onclick:stopPropagation="true">
            <div class="edit-header">
                <h3>Edit Product</h3>
                <button class="cd-close" @onclick="CloseEdit">&#10005;</button>
            </div>
            <div class="edit-body">
                <div class="edit-image-section">
                    @if (!string.IsNullOrWhiteSpace(editImagePath))
                    {
                        <img src="@GetImageSource(editImagePath)"
                             class="edit-image-preview" alt="Product image" />
                    }
                    else
                    {
                        <div class="edit-no-image">
                            <span>&#128247;</span>
                            <p>No image</p>
                        </div>
                    }
                    <button class="btn btn-sm btn-outline-secondary mt-2"
                            @onclick="PickEditImageAsync">
                        &#128247; Upload Image
                    </button>
                </div>

                <div class="edit-field">
                    <label>Name</label>
                    <input type="text" @bind="editName" placeholder="Product name" />
                </div>
                <div class="edit-field">
                    <label>SKU</label>
                    <input type="text" @bind="editSku" placeholder="SKU" />
                </div>
                <div class="edit-row">
                    <div class="edit-field">
                        <label>Quantity</label>
                        <input type="number" @bind="editQuantity" min="0" />
                    </div>
                    <div class="edit-field">
                        <label>Sale Price</label>
                        <input type="number" @bind="editSalePrice" min="0" />
                    </div>
                    <div class="edit-field">
                        <label>Cost Price</label>
                        <input type="number" @bind="editCostPrice" min="0" />
                    </div>
                </div>
                <div class="edit-row">
                    <div class="edit-field">
                        <label>Category</label>
                        <input type="text" @bind="editCategory" placeholder="Category" />
                    </div>
                    <div class="edit-field">
                        <label>Unit</label>
                        <input type="text" @bind="editUnit" placeholder="e.g. pcs, kg" />
                    </div>
                </div>
            </div>
            <div class="edit-footer">
                <button class="cd-btn cd-btn-light" @onclick="CloseEdit">Cancel</button>
                <button class="cd-btn cd-btn-primary" @onclick="ConfirmEdit">Save Changes</button>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation -->
<ConfirmDialog IsOpen="showDeleteConfirm"
               Title="Delete Product"
               Message="@($"Are you sure you want to delete \"{productToDelete?.Name}\"? This cannot be undone.")"
               ConfirmText="Delete"
               CancelText="Cancel"
               IsDanger="true"
               OnConfirm="ConfirmDelete"
               OnCancel="CancelDelete" />

@code {
    [Parameter] public List<ProductDto> Products { get; set; } = new();
    [Parameter] public EventCallback<Guid> OnIncreaseQuantity { get; set; }
    [Parameter] public EventCallback<Guid> OnDecreaseQuantity { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteProduct { get; set; }
    [Parameter] public EventCallback<ProductDto> OnEditProduct { get; set; }

    private Dictionary<string, string> _imageCache = new();

    // All products fetched from service
    private List<ProductDto> _allProducts = new();

    // After filters applied
    private List<ProductDto> _filtered = new();

    // Current page slice
    private List<ProductDto> _paginated = new();

    private string _search = "";
    private int _page = 1;
    private const int PageSize = 10;
    private int _totalPages = 1;
    private bool _loading = false;
    private System.Timers.Timer? _debounce;

    // Filters
    private string _categoryFilter = "";
    private string _stockFilter = "";
    private List<string> _categories = new();

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_categoryFilter) ||
        !string.IsNullOrWhiteSpace(_stockFilter);

    private int StartPage => Math.Max(1, _page - 2);
    private int EndPage => Math.Min(_totalPages, StartPage + 4);

    // Modal state
    private bool showDeleteConfirm = false;
    private ProductDto? productToDelete;
    private bool showEditModal = false;
    private ProductDto? editingProduct;
    private string editName = "";
    private string editSku = "";
    private int editQuantity = 0;
    private decimal editSalePrice = 0;
    private decimal editCostPrice = 0;
    private string editCategory = "";
    private string editUnit = "";
    private string editImagePath = "";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    public async Task RefreshAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        // Fetch all products once
        var result = await ProductService.GetPagedAsync("", 1, 9999);
        _allProducts = result.Items;

        // Populate category list
        _categories = _allProducts
            .Select(p => p.Category)
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .Distinct()
            .OrderBy(c => c)
            .Select(c => c!)
            .ToList();

        ApplyFiltersAndPaginate();

        _loading = false;
        StateHasChanged();
    }

    private void ApplyFiltersAndPaginate()
    {
        var filtered = _allProducts.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var q = _search.ToLowerInvariant();
            filtered = filtered.Where(p =>
                p.Name.ToLowerInvariant().Contains(q) ||
                (p.Sku != null && p.Sku.ToLowerInvariant().Contains(q)));
        }

        if (!string.IsNullOrWhiteSpace(_categoryFilter))
            filtered = filtered.Where(p => p.Category == _categoryFilter);

        if (_stockFilter == "instock")
            filtered = filtered.Where(p => p.Quantity > 10);
        else if (_stockFilter == "lowstock")
            filtered = filtered.Where(p => p.Quantity > 0 && p.Quantity <= 10);
        else if (_stockFilter == "outofstock")
            filtered = filtered.Where(p => p.Quantity <= 0);

        _filtered = filtered.ToList();
        _totalPages = (int)Math.Ceiling(_filtered.Count / (double)PageSize);
        if (_totalPages == 0) _totalPages = 1;

        if (_page > _totalPages) _page = _totalPages;

        _paginated = _filtered
            .Skip((_page - 1) * PageSize)
            .Take(PageSize)
            .ToList();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        _page = 1;

        _debounce?.Stop();
        _debounce?.Dispose();
        _debounce = new System.Timers.Timer(300);
        _debounce.Elapsed += async (_, _) =>
        {
            _debounce?.Dispose();
            await InvokeAsync(() => { ApplyFiltersAndPaginate(); StateHasChanged(); });
        };
        _debounce.AutoReset = false;
        _debounce.Start();
    }

    private void OnCategoryChange(ChangeEventArgs e)
    {
        _categoryFilter = e.Value?.ToString() ?? "";
        _page = 1;
        ApplyFiltersAndPaginate();
    }

    private void OnStockFilterChange(ChangeEventArgs e)
    {
        _stockFilter = e.Value?.ToString() ?? "";
        _page = 1;
        ApplyFiltersAndPaginate();
    }

    private void ResetFilters()
    {
        _categoryFilter = "";
        _stockFilter = "";
        _page = 1;
        ApplyFiltersAndPaginate();
    }

    private void RemoveCategoryFilter() { _categoryFilter = ""; _page = 1; ApplyFiltersAndPaginate(); }
    private void RemoveStockFilter() { _stockFilter = ""; _page = 1; ApplyFiltersAndPaginate(); }

    private void GoToPage(int page)
    {
        _page = page;
        ApplyFiltersAndPaginate();
    }

    private string GetStockLabel(string s) => s switch
    {
        "instock" => "In Stock",
        "lowstock" => "Low Stock",
        "outofstock" => "Out of Stock",
        _ => ""
    };

    private async Task AdjustStock(Guid id, int delta)
    {
        if (delta > 0) await OnIncreaseQuantity.InvokeAsync(id);
        else await OnDecreaseQuantity.InvokeAsync(id);

        var item = _allProducts.FirstOrDefault(p => p.Id == id);
        if (item != null)
        {
            item.Quantity = Math.Max(0, item.Quantity + delta);
            ApplyFiltersAndPaginate();
            StateHasChanged();
        }
    }

    private void AskDelete(ProductDto product)
    {
        productToDelete = product;
        showDeleteConfirm = true;
    }

    private async Task ConfirmDelete()
    {
        showDeleteConfirm = false;
        if (productToDelete != null)
        {
            await OnDeleteProduct.InvokeAsync(productToDelete.Id);
            await LoadAsync();
        }
        productToDelete = null;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        productToDelete = null;
    }

    private void OpenEdit(ProductDto product)
    {
        editingProduct = product;
        editName = product.Name;
        editSku = product.Sku;
        editQuantity = product.Quantity;
        editSalePrice = product.SalePrice;
        editCostPrice = product.CostPrice;
        editCategory = product.Category ?? "";
        editUnit = product.Unit ?? "";
        editImagePath = product.ImagePath ?? "";
        showEditModal = true;
    }

    private void CloseEdit()
    {
        showEditModal = false;
        editingProduct = null;
    }

    private async Task PickEditImageAsync()
    {
        var file = await FilePicker.Default.PickAsync(new PickOptions
        {
            PickerTitle = "Select product image",
            FileTypes = FilePickerFileType.Images
        });

        if (file is null) return;

        var extension = Path.GetExtension(file.FileName);
        var fileName = $"{Guid.NewGuid()}{extension}";
        var localPath = Path.Combine(FileSystem.AppDataDirectory, fileName);

        await using (var src = await file.OpenReadAsync())
        await using (var dest = File.Create(localPath))
            await src.CopyToAsync(dest);

        _imageCache.Remove(localPath);
        editImagePath = localPath;
        StateHasChanged();
    }

    private async Task ConfirmEdit()
    {
        if (editingProduct == null) return;

        var updated = new ProductDto
        {
            Id = editingProduct.Id,
            Name = editName.Trim(),
            Sku = editSku.Trim(),
            Quantity = editQuantity,
            SalePrice = editSalePrice,
            CostPrice = editCostPrice,
            Category = editCategory.Trim(),
            Unit = editUnit.Trim(),
            ImagePath = editImagePath
        };

        await OnEditProduct.InvokeAsync(updated);

        var local = _allProducts.FirstOrDefault(p => p.Id == updated.Id);
        if (local != null)
        {
            local.Name = updated.Name;
            local.Sku = updated.Sku;
            local.Quantity = updated.Quantity;
            local.SalePrice = updated.SalePrice;
            local.CostPrice = updated.CostPrice;
            local.Category = updated.Category;
            local.Unit = updated.Unit;
            local.ImagePath = updated.ImagePath;
        }

        CloseEdit();
        ApplyFiltersAndPaginate();
        StateHasChanged();
    }

    private string GetImageSource(string? path)
    {
        if (string.IsNullOrWhiteSpace(path)) return "";
        if (!File.Exists(path)) return "";

        if (_imageCache.TryGetValue(path, out var cached))
            return cached;

        try
        {
            using var stream = new FileStream(path, FileMode.Open, FileAccess.Read, FileShare.ReadWrite);
            using var ms = new MemoryStream();
            stream.CopyTo(ms);

            var mime = Path.GetExtension(path).ToLowerInvariant() switch
            {
                ".png" => "image/png",
                ".jpg" or ".jpeg" => "image/jpeg",
                ".webp" => "image/webp",
                ".gif" => "image/gif",
                _ => "image/jpeg"
            };

            var result = $"data:{mime};base64,{Convert.ToBase64String(ms.ToArray())}";
            _imageCache[path] = result;
            return result;
        }
        catch { return ""; }
    }
}
