@using ShopInventory.Application.DTOs
@using ShopInventory.Application.Interfaces
@inject IProductService ProductService

<div class="tab-card">
    <div class="section-top">
        <h5>All Products</h5>
        <input class="form-control search-box"
               placeholder="Search by name, SKU or category"
               value="@_search"
               @oninput="OnSearchInput" />
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <div class="filter-row">
            <div class="filter-group">
                <label class="filter-label">Category</label>
                <select class="filter-select" value="@_categoryFilter" @onchange="OnCategoryChange">
                    <option value="">All Categories</option>
                    @foreach (var cat in _categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>

            <div class="filter-group">
                <label class="filter-label">Min Price</label>
                <input class="filter-input" type="number" min="0" placeholder="0.00"
                       value="@_minPrice"
                       @onchange="OnMinPriceChange" />
            </div>

            <div class="filter-group">
                <label class="filter-label">Max Price</label>
                <input class="filter-input" type="number" min="0" placeholder="Any"
                       value="@_maxPrice"
                       @onchange="OnMaxPriceChange" />
            </div>

            <div class="filter-group">
                <label class="filter-label">Stock</label>
                <select class="filter-select" value="@_stockFilter" @onchange="OnStockFilterChange">
                    <option value="">All</option>
                    <option value="instock">In Stock</option>
                    <option value="lowstock">Low Stock (&#8804;10)</option>
                    <option value="outofstock">Out of Stock</option>
                </select>
            </div>

            <div class="filter-group">
                <label class="filter-label">Sort By</label>
                <select class="filter-select" value="@_sortBy" @onchange="OnSortChange">
                    <option value="">Default</option>
                    <option value="price_asc">Price: Low to High</option>
                    <option value="price_desc">Price: High to Low</option>
                    <option value="qty_asc">Quantity: Low to High</option>
                    <option value="qty_desc">Quantity: High to Low</option>
                    <option value="name_asc">Name: A to Z</option>
                    <option value="name_desc">Name: Z to A</option>
                </select>
            </div>

            @if (HasActiveFilters)
            {
                <button class="filter-reset-btn" @onclick="ResetFilters">&#10005; Clear Filters</button>
            }
        </div>
    </div>

    <!-- Active Filter Pills -->
    @if (HasActiveFilters)
    {
        <div class="filter-pills">
            @if (!string.IsNullOrWhiteSpace(_categoryFilter))
            {
                <span class="filter-pill">
                    &#128193; @_categoryFilter
                    <button @onclick="RemoveCategoryFilter">&#215;</button>
                </span>
            }
            @if (_minPrice.HasValue || _maxPrice.HasValue)
            {
                <span class="filter-pill">
                    &#128176; @(_minPrice.HasValue ? "from " + _minPrice.Value.ToString("F0") : "") @(_maxPrice.HasValue ? "to " + _maxPrice.Value.ToString("F0") : "")
                    <button @onclick="RemovePriceFilter">&#215;</button>
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(_stockFilter))
            {
                <span class="filter-pill">
                    &#128230; @GetStockLabel(_stockFilter)
                    <button @onclick="RemoveStockFilter">&#215;</button>
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(_sortBy))
            {
                <span class="filter-pill">
                    &#8597; @GetSortLabel(_sortBy)
                    <button @onclick="RemoveSortFilter">&#215;</button>
                </span>
            }
        </div>
    }

    @if (_loading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading products...</p>
        </div>
    }
    else if (_paged.Items.Count == 0)
    {
        <div class="empty-state">
            <span>&#128230;</span>
            <p>
                @(string.IsNullOrWhiteSpace(_search) && !HasActiveFilters
                            ? "No products found. Add your first product!"
                            : "No results found. Try adjusting your filters.")
        </p>
    </div>
        }
    else
    {
        <div class="products-grid">
            @foreach (var product in _paged.Items)
            {
                <ProductCard ProductId="@product.Id"
                             Name="@product.Name"
                             Sku="@product.Sku"
                             SalePrice="@product.SalePrice.ToString("F2")"
                             CostPrice="@product.CostPrice.ToString("F2")"
                             Quantity="@product.Quantity"
                             Category="@(product.Category ?? "")"
                             Unit="@(product.Unit ?? "")"
                             ImageUrl="@GetImageSource(product.ImagePath)"
                             OldPrice="@(product.OldPrice.HasValue ? product.OldPrice.Value.ToString("F2") : "")" />
            }
        </div>

        @if (_paged.TotalPages > 1)
        {
            <div class="pagination-bar">
                <button class="pg-btn" disabled="@(!_paged.HasPrev)" @onclick="@(() => GoToPage(_page - 1))">&#8592;</button>

                @for (int i = StartPage; i <= EndPage; i++)
                {
                    var pageNum = i;
                    <button class="pg-btn @(pageNum == _page ? "pg-active" : "")"
                            @onclick="@(() => GoToPage(pageNum))">
                        @pageNum
                    </button>
                }

                <button class="pg-btn" disabled="@(!_paged.HasNext)" @onclick="@(() => GoToPage(_page + 1))">&#8594;</button>
                <span class="pg-info">@_paged.TotalCount products</span>
            </div>
        }
    }
</div>

@code {
    [Parameter] public List<ProductDto> Products { get; set; } = new();
    [Parameter] public EventCallback<string> OnSearch { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }
    [Parameter] public EventCallback OnRefreshNeeded { get; set; }

    private PagedResult<ProductDto> _paged = new() { Items = new(), PageSize = 20, Page = 1 };
    private string _search = "";
    private int _page = 1;
    private const int PageSize = 20;
    private bool _loading = false;
    private System.Timers.Timer? _debounce;
    private Dictionary<string, string> _imageCache = new();

    // Filter state
    private string _categoryFilter = "";
    private decimal? _minPrice = null;
    private decimal? _maxPrice = null;
    private string _stockFilter = "";
    private string _sortBy = "";
    private List<string> _categories = new();

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_categoryFilter) ||
        _minPrice.HasValue ||
        _maxPrice.HasValue ||
        !string.IsNullOrWhiteSpace(_stockFilter) ||
        !string.IsNullOrWhiteSpace(_sortBy);

    private int StartPage => Math.Max(1, _page - 2);
    private int EndPage => Math.Min(_paged.TotalPages, StartPage + 4);

    protected override async Task OnInitializedAsync()
    {
        await LoadCategoriesAsync();
        await LoadAsync();
    }

    public async Task RefreshAsync()
    {
        _page = 1;
        await LoadCategoriesAsync();
        await LoadAsync();
    }

    private async Task LoadCategoriesAsync()
    {
        var all = await ProductService.GetPagedAsync("", 1, 9999);
        _categories = all.Items
            .Select(p => p.Category)
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .Distinct()
            .OrderBy(c => c)
            .Select(c => c!)
            .ToList();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        var all = await ProductService.GetPagedAsync("", 1, 9999);
        var filtered = all.Items.AsEnumerable();

        // Search
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var q = _search.ToLowerInvariant();
            filtered = filtered.Where(p =>
                p.Name.ToLowerInvariant().Contains(q) ||
                (p.Sku != null && p.Sku.ToLowerInvariant().Contains(q)) ||
                (p.Category != null && p.Category.ToLowerInvariant().Contains(q)));
        }

        // Category
        if (!string.IsNullOrWhiteSpace(_categoryFilter))
            filtered = filtered.Where(p => p.Category == _categoryFilter);

        // Price range
        if (_minPrice.HasValue)
            filtered = filtered.Where(p => p.SalePrice >= _minPrice.Value);
        if (_maxPrice.HasValue)
            filtered = filtered.Where(p => p.SalePrice <= _maxPrice.Value);

        // Stock
        if (_stockFilter == "instock")
            filtered = filtered.Where(p => p.Quantity > 10);
        else if (_stockFilter == "lowstock")
            filtered = filtered.Where(p => p.Quantity > 0 && p.Quantity <= 10);
        else if (_stockFilter == "outofstock")
            filtered = filtered.Where(p => p.Quantity <= 0);

        // Sort
        if (_sortBy == "price_asc")
            filtered = filtered.OrderBy(p => p.SalePrice);
        else if (_sortBy == "price_desc")
            filtered = filtered.OrderByDescending(p => p.SalePrice);
        else if (_sortBy == "qty_asc")
            filtered = filtered.OrderBy(p => p.Quantity);
        else if (_sortBy == "qty_desc")
            filtered = filtered.OrderByDescending(p => p.Quantity);
        else if (_sortBy == "name_asc")
            filtered = filtered.OrderBy(p => p.Name);
        else if (_sortBy == "name_desc")
            filtered = filtered.OrderByDescending(p => p.Name);

        var list = filtered.ToList();
        var totalCount = list.Count;
        var totalPages = (int)Math.Ceiling(totalCount / (double)PageSize);

        if (_page > totalPages && totalPages > 0)
            _page = totalPages;

        _paged = new PagedResult<ProductDto>
        {
            Items = list.Skip((_page - 1) * PageSize).Take(PageSize).ToList(),
            TotalCount = totalCount,
            Page = _page,
            PageSize = PageSize
        };

        _loading = false;
        StateHasChanged();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        _page = 1;
        TriggerDebounce();
    }

    private async Task OnCategoryChange(ChangeEventArgs e)
    {
        _categoryFilter = e.Value?.ToString() ?? "";
        await ApplyFilters();
    }

    private async Task OnMinPriceChange(ChangeEventArgs e)
    {
        _minPrice = decimal.TryParse(e.Value?.ToString(), out var v) ? v : (decimal?)null;
        await ApplyFilters();
    }

    private async Task OnMaxPriceChange(ChangeEventArgs e)
    {
        _maxPrice = decimal.TryParse(e.Value?.ToString(), out var v) ? v : (decimal?)null;
        await ApplyFilters();
    }

    private async Task OnStockFilterChange(ChangeEventArgs e)
    {
        _stockFilter = e.Value?.ToString() ?? "";
        await ApplyFilters();
    }

    private async Task OnSortChange(ChangeEventArgs e)
    {
        _sortBy = e.Value?.ToString() ?? "";
        await ApplyFilters();
    }

    private async Task ApplyFilters()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task ResetFilters()
    {
        _categoryFilter = "";
        _minPrice = null;
        _maxPrice = null;
        _stockFilter = "";
        _sortBy = "";
        _page = 1;
        await LoadAsync();
    }

    private async Task RemoveCategoryFilter() { _categoryFilter = ""; await ApplyFilters(); }
    private async Task RemovePriceFilter() { _minPrice = null; _maxPrice = null; await ApplyFilters(); }
    private async Task RemoveStockFilter() { _stockFilter = ""; await ApplyFilters(); }
    private async Task RemoveSortFilter() { _sortBy = ""; await ApplyFilters(); }

    private void TriggerDebounce()
    {
        _debounce?.Stop();
        _debounce?.Dispose();
        _debounce = new System.Timers.Timer(300);
        _debounce.Elapsed += async (_, _) =>
        {
            _debounce?.Dispose();
            await InvokeAsync(LoadAsync);
        };
        _debounce.AutoReset = false;
        _debounce.Start();
    }

    private async Task GoToPage(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private string GetSortLabel(string sort) => sort switch
    {
        "price_asc" => "Price Low-High",
        "price_desc" => "Price High-Low",
        "qty_asc" => "Qty Low-High",
        "qty_desc" => "Qty High-Low",
        "name_asc" => "Name A-Z",
        "name_desc" => "Name Z-A",
        _ => ""
    };

    private string GetStockLabel(string stock) => stock switch
    {
        "instock" => "In Stock",
        "lowstock" => "Low Stock",
        "outofstock" => "Out of Stock",
        _ => ""
    };

    private string GetImageSource(string? path)
    {
        if (string.IsNullOrWhiteSpace(path)) return "";
        if (!File.Exists(path)) return "";

        if (_imageCache.TryGetValue(path, out var cached))
            return cached;

        try
        {
            using var stream = new FileStream(path, FileMode.Open, FileAccess.Read, FileShare.ReadWrite);
            using var ms = new MemoryStream();
            stream.CopyTo(ms);

            var mime = Path.GetExtension(path).ToLowerInvariant() switch
            {
                ".png" => "image/png",
                ".jpg" or ".jpeg" => "image/jpeg",
                ".webp" => "image/webp",
                ".gif" => "image/gif",
                _ => "image/jpeg"
            };

            var result = $"data:{mime};base64,{Convert.ToBase64String(ms.ToArray())}";
            _imageCache[path] = result;
            return result;
        }
        catch { return ""; }
    }
}
