@using ShopInventory.Application.DTOs

<div class="tab-card">
    <div class="section-top">
        <h5>All Products</h5>

        <InputText class="form-control search-box"
                   placeholder="Search by name, SKU or category"
                   @bind-Value="searchText" />

        <button class="btn btn-dark" @onclick="SearchAsync">Search</button>
        <button class="btn btn-outline-secondary" @onclick="ResetAsync">Reset</button>
    </div>

    @if (Products.Count == 0)
    {
        <div class="empty-state">
            <span>📦</span>
            <p>No products found. Add your first product!</p>
        </div>
    }
    else
    {
        <div class="products-grid">
            @foreach (var product in Products)
            {
                <ProductCard ProductId="@product.Id"
                             Name="@product.Name"
                             Sku="@product.Sku"
                             SalePrice="@product.SalePrice.ToString("F2")"
                             CostPrice="@product.CostPrice.ToString("F2")"
                             Quantity="@product.Quantity"
                             Category="@(product.Category ?? "")"
                             Unit="@(product.Unit ?? "")"
                             ImageUrl="@GetImageSource(product.ImagePath)" />
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<ProductDto> Products { get; set; } = new();
    [Parameter] public EventCallback<string> OnSearch { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }

    private string searchText = string.Empty;

    private async Task SearchAsync()
    {
        await OnSearch.InvokeAsync(searchText);
    }

    private async Task ResetAsync()
    {
        searchText = string.Empty;
        await OnReset.InvokeAsync();
    }

    private string GetImageSource(string? path)
    {
        if (string.IsNullOrWhiteSpace(path)) return "";

        if (path.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return path;

        if (File.Exists(path))
        {
            var bytes = File.ReadAllBytes(path);
            var ext = Path.GetExtension(path).ToLowerInvariant();
            var mime = ext switch
            {
                ".png" => "image/png",
                ".jpg" or ".jpeg" => "image/jpeg",
                ".webp" => "image/webp",
                ".gif" => "image/gif",
                _ => "application/octet-stream"
            };

            return $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
        }

        return "";
    }
}