@inherits LayoutComponentBase
@using ShopInventory.App.Services
@inject LicenseService LicenseService

@if (appState == AppState.Splash)
{
    <!-- SPLASH SCREEN -->
    <div class="splash-screen @(splashFading ? "fade-out" : "")">
        <div class="splash-content">
            <div class="gear-wrap">
                <svg class="gear-spin" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <path fill="#cc0000" d="M43.3 5.6l-3.1 9.5c-2.3.6-4.5 1.5-6.5 2.7L24.4 13l-9 9 4.8 9.3c-1.2 2-2.1 4.2-2.7 6.5l-9.5 3.1v12.7l9.5 3.1c.6 2.3 1.5 4.5 2.7 6.5L15.4 73l9 9 9.3-4.8c2 1.2 4.2 2.1 6.5 2.7l3.1 9.5h12.7l3.1-9.5c2.3-.6 4.5-1.5 6.5-2.7l9.3 4.8 9-9-4.8-9.3c1.2-2 2.1-4.2 2.7-6.5l9.5-3.1V43.3l-9.5-3.1c-.6-2.3-1.5-4.5-2.7-6.5l4.8-9.3-9-9-9.3 4.8c-2-1.2-4.2-2.1-6.5-2.7l-3.1-9.5H43.3zM50 34c8.8 0 16 7.2 16 16s-7.2 16-16 16-16-7.2-16-16 7.2-16 16-16z"/>
                    <circle fill="#1a1a1a" cx="50" cy="50" r="10"/>
                </svg>
                <svg class="wrench" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path fill="#888" d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
                </svg>
            </div>

            <div class="splash-title-wrap">
                <div class="splash-arabic">شیر ربانی آٹوز</div>
                <div class="splash-divider">
                    <span class="divider-line"></span>
                    <span class="divider-text">Sheer Rabbani Autos</span>
                    <span class="divider-line"></span>
                </div>
                <div class="splash-sub">Inventory & Billing System</div>
            </div>

            <div class="splash-loader">
                <div class="loader-bar"></div>
            </div>
        </div>
    </div>
}
else if (appState == AppState.Activation)
{
    <!-- LICENSE ACTIVATION SCREEN -->
    <div class="activate-page">
        <div class="activate-card">
            <div class="app-logo">
                <div class="logo-icon">
                    <svg viewBox="0 0 100 100" width="32" height="32">
                        <path fill="#cc0000" d="M43.3 5.6l-3.1 9.5c-2.3.6-4.5 1.5-6.5 2.7L24.4 13l-9 9 4.8 9.3c-1.2 2-2.1 4.2-2.7 6.5l-9.5 3.1v12.7l9.5 3.1c.6 2.3 1.5 4.5 2.7 6.5L15.4 73l9 9 9.3-4.8c2 1.2 4.2 2.1 6.5 2.7l3.1 9.5h12.7l3.1-9.5c2.3-.6 4.5-1.5 6.5-2.7l9.3 4.8 9-9-4.8-9.3c1.2-2 2.1-4.2 2.7-6.5l9.5-3.1V43.3l-9.5-3.1c-.6-2.3-1.5-4.5-2.7-6.5l4.8-9.3-9-9-9.3 4.8c-2-1.2-4.2-2.1-6.5-2.7l-3.1-9.5H43.3z"/>
                    </svg>
                </div>
                <div>
                    <div class="app-name">Sheer Rabbani Autos</div>
                    <div class="app-tagline">Inventory & Billing System</div>
                </div>
            </div>

            @if (licenseMessage != "")
            {
                <div class="alert @licenseAlertClass">
                    <strong>@licenseTitle</strong>
                    <p>@licenseMessage</p>
                </div>
            }

            <div class="machine-id-box">
                <div class="mid-label">Your Machine ID <span class="mid-hint">(send to your provider)</span></div>
                <div class="mid-value">@machineId</div>
                <button class="btn-copy" @onclick="CopyMachineId">@(copied ? "✓ Copied!" : "📋 Copy")</button>
            </div>

            <div class="form-section">
                <label class="input-label">Enter License Key</label>
                <textarea class="key-input" placeholder="Paste your license key here..." @bind="licenseKey" rows="3"></textarea>
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-msg">@errorMessage</div>
                }
                <button class="btn-activate" @onclick="Activate" @disabled="isActivating">
                    @(isActivating ? "Activating..." : "Activate License")
                </button>
            </div>

            <div class="contact-box">
                <div class="contact-box-title">Need a license key?</div>
                <div class="contact-box-row">
                    <span>📱 WhatsApp</span>
                    <span>+92 342 3896298</span>
                </div>
                <div class="contact-box-row">
                    <span>📧 Email</span>
                    <span>umer23672@gmail.com</span>
                </div>
                <div class="contact-box-note">Send your Machine ID above to get activated</div>
            </div>
        </div>
    </div>
}
else
{
    <!-- NORMAL APP -->
    <div class="app-shell">
        <aside class="sidebar">
            <NavMenu />
        </aside>
        <main class="main-content">
            <div class="content-wrap">
                @Body
            </div>
        </main>
    </div>
}

@code {
    private enum AppState { Splash, Activation, App }

    private AppState appState = AppState.Splash;
    private bool splashFading = false;
    private string machineId = "";
    private string licenseKey = "";
    private string errorMessage = "";
    private string licenseMessage = "";
    private string licenseTitle = "";
    private string licenseAlertClass = "";
    private bool isActivating = false;
    private bool copied = false;

    protected override async Task OnInitializedAsync()
    {
        machineId = LicenseService.GetMachineId();

        // Show splash for 3 seconds
        await Task.Delay(2800);
        splashFading = true;
        StateHasChanged();
        await Task.Delay(500);

        // Check license
        var result = LicenseService.CheckCurrentLicense();
        if (result.IsValid)
        {
            appState = AppState.App;
        }
        else
        {
            appState = AppState.Activation;
            SetLicenseAlert(result.Status);
        }

        StateHasChanged();
    }

    private void SetLicenseAlert(LicenseStatus status)
    {
        switch (status)
        {
            case LicenseStatus.Expired:
                licenseTitle = "License Expired";
                licenseMessage = "Your license has expired. Please contact your provider to renew.";
                licenseAlertClass = "alert-expired";
                break;
            case LicenseStatus.WrongMachine:
                licenseTitle = "Wrong Machine";
                licenseMessage = "This license is registered to a different machine.";
                licenseAlertClass = "alert-error";
                break;
            case LicenseStatus.NotActivated:
                licenseTitle = "";
                licenseMessage = "";
                break;
        }
    }

    private async Task Activate()
    {
        if (string.IsNullOrWhiteSpace(licenseKey))
        {
            errorMessage = "Please enter a license key.";
            return;
        }
        isActivating = true;
        errorMessage = "";
        await Task.Delay(600);

        var result = LicenseService.ValidateLicenseKey(licenseKey);
        if (result.IsValid)
        {
            appState = AppState.App;
        }
        else
        {
            errorMessage = result.Message;
            SetLicenseAlert(result.Status);
        }
        isActivating = false;
        StateHasChanged();
    }

    private async Task CopyMachineId()
    {
        await Clipboard.Default.SetTextAsync(machineId);
        copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        copied = false;
        StateHasChanged();
    }
}

