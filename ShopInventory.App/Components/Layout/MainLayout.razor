@inherits LayoutComponentBase
@using ShopInventory.App.Services
@inject LicenseService LicenseService

@if (appState == AppState.Splash)
{
    <!-- SPLASH SCREEN -->
    <div class="splash-screen @(splashFading ? "fade-out" : "")">
        <div class="splash-content">
            <div class="gear-wrap">
                <svg class="gear-spin" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <path fill="#cc0000" d="M43.3 5.6l-3.1 9.5c-2.3.6-4.5 1.5-6.5 2.7L24.4 13l-9 9 4.8 9.3c-1.2 2-2.1 4.2-2.7 6.5l-9.5 3.1v12.7l9.5 3.1c.6 2.3 1.5 4.5 2.7 6.5L15.4 73l9 9 9.3-4.8c2 1.2 4.2 2.1 6.5 2.7l3.1 9.5h12.7l3.1-9.5c2.3-.6 4.5-1.5 6.5-2.7l9.3 4.8 9-9-4.8-9.3c1.2-2 2.1-4.2 2.7-6.5l9.5-3.1V43.3l-9.5-3.1c-.6-2.3-1.5-4.5-2.7-6.5l4.8-9.3-9-9-9.3 4.8c-2-1.2-4.2-2.1-6.5-2.7l-3.1-9.5H43.3zM50 34c8.8 0 16 7.2 16 16s-7.2 16-16 16-16-7.2-16-16 7.2-16 16-16z"/>
                    <circle fill="#1a1a1a" cx="50" cy="50" r="10"/>
                </svg>
                <svg class="wrench" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path fill="#888" d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
                </svg>
            </div>

            <div class="splash-title-wrap">
                <div class="splash-arabic">شیر ربانی آٹوز</div>
                <div class="splash-divider">
                    <span class="divider-line"></span>
                    <span class="divider-text">Sheer Rabbani Autos</span>
                    <span class="divider-line"></span>
                </div>
                <div class="splash-sub">Inventory & Billing System</div>
            </div>

            <div class="splash-loader">
                <div class="loader-bar"></div>
            </div>
        </div>
    </div>
}
else if (appState == AppState.Activation)
{
    <!-- LICENSE ACTIVATION SCREEN -->
    <div class="activate-page">
        <div class="activate-card">
            <div class="app-logo">
                <div class="logo-icon">
                    <svg viewBox="0 0 100 100" width="32" height="32">
                        <path fill="#cc0000" d="M43.3 5.6l-3.1 9.5c-2.3.6-4.5 1.5-6.5 2.7L24.4 13l-9 9 4.8 9.3c-1.2 2-2.1 4.2-2.7 6.5l-9.5 3.1v12.7l9.5 3.1c.6 2.3 1.5 4.5 2.7 6.5L15.4 73l9 9 9.3-4.8c2 1.2 4.2 2.1 6.5 2.7l3.1 9.5h12.7l3.1-9.5c2.3-.6 4.5-1.5 6.5-2.7l9.3 4.8 9-9-4.8-9.3c1.2-2 2.1-4.2 2.7-6.5l9.5-3.1V43.3l-9.5-3.1c-.6-2.3-1.5-4.5-2.7-6.5l4.8-9.3-9-9-9.3 4.8c-2-1.2-4.2-2.1-6.5-2.7l-3.1-9.5H43.3z"/>
                    </svg>
                </div>
                <div>
                    <div class="app-name">Sheer Rabbani Autos</div>
                    <div class="app-tagline">Inventory & Billing System</div>
                </div>
            </div>

            @if (licenseMessage != "")
            {
                <div class="alert @licenseAlertClass">
                    <strong>@licenseTitle</strong>
                    <p>@licenseMessage</p>
                </div>
            }

            <div class="machine-id-box">
                <div class="mid-label">Your Machine ID <span class="mid-hint">(send to your provider)</span></div>
                <div class="mid-value">@machineId</div>
                <button class="btn-copy" @onclick="CopyMachineId">@(copied ? "✓ Copied!" : "📋 Copy")</button>
            </div>

            <div class="form-section">
                <label class="input-label">Enter License Key</label>
                <textarea class="key-input" placeholder="Paste your license key here..." @bind="licenseKey" rows="3"></textarea>
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-msg">@errorMessage</div>
                }
                <button class="btn-activate" @onclick="Activate" @disabled="isActivating">
                    @(isActivating ? "Activating..." : "Activate License")
                </button>
            </div>

            <div class="contact-box">
                <div class="contact-box-title">Need a license key?</div>
                <div class="contact-box-row">
                    <span>📱 WhatsApp</span>
                    <span>+92 342 3896298</span>
                </div>
                <div class="contact-box-row">
                    <span>📧 Email</span>
                    <span>umer23672@gmail.com</span>
                </div>
                <div class="contact-box-note">Send your Machine ID above to get activated</div>
            </div>
        </div>
    </div>
}
else
{
    <!-- NORMAL APP -->
    <div class="app-shell">
        <aside class="sidebar">
            <NavMenu />
        </aside>
        <main class="main-content">
            <div class="content-wrap">
                @Body
            </div>
        </main>
    </div>
}

@code {
    private enum AppState { Splash, Activation, App }

    private AppState appState = AppState.Splash;
    private bool splashFading = false;
    private string machineId = "";
    private string licenseKey = "";
    private string errorMessage = "";
    private string licenseMessage = "";
    private string licenseTitle = "";
    private string licenseAlertClass = "";
    private bool isActivating = false;
    private bool copied = false;

    protected override async Task OnInitializedAsync()
    {
        machineId = LicenseService.GetMachineId();

        // Show splash for 3 seconds
        await Task.Delay(2800);
        splashFading = true;
        StateHasChanged();
        await Task.Delay(500);

        // Check license
        var result = LicenseService.CheckCurrentLicense();
        if (result.IsValid)
        {
            appState = AppState.App;
        }
        else
        {
            appState = AppState.Activation;
            SetLicenseAlert(result.Status);
        }

        StateHasChanged();
    }

    private void SetLicenseAlert(LicenseStatus status)
    {
        switch (status)
        {
            case LicenseStatus.Expired:
                licenseTitle = "License Expired";
                licenseMessage = "Your license has expired. Please contact your provider to renew.";
                licenseAlertClass = "alert-expired";
                break;
            case LicenseStatus.WrongMachine:
                licenseTitle = "Wrong Machine";
                licenseMessage = "This license is registered to a different machine.";
                licenseAlertClass = "alert-error";
                break;
            case LicenseStatus.NotActivated:
                licenseTitle = "";
                licenseMessage = "";
                break;
        }
    }

    private async Task Activate()
    {
        if (string.IsNullOrWhiteSpace(licenseKey))
        {
            errorMessage = "Please enter a license key.";
            return;
        }
        isActivating = true;
        errorMessage = "";
        await Task.Delay(600);

        var result = LicenseService.ValidateLicenseKey(licenseKey);
        if (result.IsValid)
        {
            appState = AppState.App;
        }
        else
        {
            errorMessage = result.Message;
            SetLicenseAlert(result.Status);
        }
        isActivating = false;
        StateHasChanged();
    }

    private async Task CopyMachineId()
    {
        await Clipboard.Default.SetTextAsync(machineId);
        copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        copied = false;
        StateHasChanged();
    }
}

<style>
/* ── SPLASH ─────────────────────────────────────── */
.splash-screen {
    position: fixed; inset: 0;
    background: #111214;
    display: flex; align-items: center; justify-content: center;
    z-index: 9999;
    transition: opacity .5s ease;
}
.splash-screen.fade-out { opacity: 0; pointer-events: none; }

.splash-content { text-align: center; }

.gear-wrap {
    position: relative;
    width: 110px; height: 110px;
    margin: 0 auto 28px;
    display: flex; align-items: center; justify-content: center;
}
.gear-spin {
    width: 110px; height: 110px;
    animation: gearRotate 3s linear infinite;
    filter: drop-shadow(0 0 18px rgba(204,0,0,.5));
}
.wrench {
    position: absolute;
    width: 36px; height: 36px;
    bottom: -4px; right: -4px;
    animation: wrenchWiggle 2s ease-in-out infinite;
}
@@keyframes gearRotate { to { transform: rotate(360deg); } }
@@keyframes wrenchWiggle {
    0%,100% { transform: rotate(-10deg); }
    50% { transform: rotate(10deg); }
}

.splash-arabic {
    font-size: 28px;
    color: #ffffff;
    font-weight: 700;
    letter-spacing: .05em;
    opacity: 0;
    animation: fadeSlideUp .8s ease .4s forwards;
    direction: rtl;
}
.splash-divider {
    display: flex; align-items: center; gap: 10px;
    justify-content: center; margin: 10px 0 6px;
    opacity: 0;
    animation: fadeSlideUp .8s ease .7s forwards;
}
.divider-line {
    flex: 1; max-width: 60px;
    height: 1px; background: #cc0000;
}
.divider-text {
    font-size: 18px; font-weight: 600;
    color: #cc0000; letter-spacing: .12em;
    text-transform: uppercase;
}
.splash-sub {
    font-size: 13px; color: #666;
    letter-spacing: .1em;
    opacity: 0;
    animation: fadeSlideUp .8s ease 1s forwards;
}

.splash-loader {
    margin-top: 48px;
    width: 200px;
    height: 3px;
    background: #2a2a2a;
    border-radius: 3px;
    overflow: hidden;
    margin-left: auto; margin-right: auto;
    opacity: 0;
    animation: fadeIn .5s ease 1.2s forwards;
}
.loader-bar {
    height: 100%;
    background: #cc0000;
    border-radius: 3px;
    animation: loadProgress 2.2s ease 1.2s forwards;
    width: 0;
}
@@keyframes loadProgress { to { width: 100%; } }
@@keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
}
@@keyframes fadeIn { to { opacity: 1; } }

/* ── ACTIVATION ─────────────────────────────────── */
.activate-page {
    min-height: 100vh;
    background: #111214;
    display: flex; align-items: center; justify-content: center;
    padding: 2rem;
}
.activate-card {
    background: #1c1e22;
    border: 1px solid #2a2a2a;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    width: 100%; max-width: 440px;
    box-shadow: 0 25px 60px rgba(0,0,0,.6);
}
.app-logo { display: flex; align-items: center; gap: 14px; margin-bottom: 2rem; }
.logo-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: #1a0000; border: 1px solid #cc0000;
    display: flex; align-items: center; justify-content: center;
}
.app-name { font-size: 17px; font-weight: 700; color: #fff; }
.app-tagline { font-size: 12px; color: #666; margin-top: 2px; }

.alert { padding: 12px 14px; border-radius: 10px; margin-bottom: 16px; font-size: 13px; }
.alert strong { display: block; font-weight: 600; margin-bottom: 2px; color: #fff; }
.alert p { margin: 0; color: #aaa; }
.alert-expired { background: #2a1f00; border: 1px solid #f59e0b; }
.alert-error   { background: #200a0a; border: 1px solid #ef4444; }

.machine-id-box {
    background: #16181c; border: 1px solid #2a2a2a;
    border-radius: 12px; padding: 12px 14px; margin-bottom: 20px;
}
.mid-label { font-size: 11px; font-weight: 600; color: #555;
    text-transform: uppercase; letter-spacing: .05em; margin-bottom: 6px; }
.mid-hint { font-weight: 400; color: #444; }
.mid-value { font-family: monospace; font-size: 16px; font-weight: 700;
    color: #cc0000; letter-spacing: .1em; margin-bottom: 8px; }
.btn-copy { font-size: 12px; padding: 4px 12px; border-radius: 6px;
    border: 1px solid #333; background: #222; cursor: pointer; color: #aaa; }
.btn-copy:hover { background: #2a2a2a; color: #fff; }

.form-section { margin-bottom: 16px; }
.input-label { font-size: 13px; font-weight: 500; color: #aaa; display: block; margin-bottom: 6px; }
.key-input {
    width: 100%; padding: 10px 12px; border: 1px solid #2a2a2a;
    border-radius: 10px; font-size: 13px; font-family: monospace;
    background: #16181c; resize: none; outline: none; color: #fff;
}
.key-input:focus { border-color: #cc0000; }
.error-msg { color: #ef4444; font-size: 13px; margin: 6px 0 10px; }
.btn-activate {
    width: 100%; padding: 12px; background: #cc0000; color: #fff;
    border: none; border-radius: 10px; font-size: 15px; font-weight: 600;
    cursor: pointer; margin-top: 10px;
}
.btn-activate:hover:not(:disabled) { background: #aa0000; }
.btn-activate:disabled { opacity: .5; cursor: not-allowed; }
.contact-box { font-size: 12px; color: #555; margin-top: 16px;
    background: #16181c; border: 1px solid #2a2a2a; border-radius: 10px; padding: 12px 14px; }
.contact-box-title { font-size: 11px; font-weight: 600; color: #666;
    text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; }
.contact-box-row { display: flex; justify-content: space-between;
    padding: 4px 0; color: #aaa; font-size: 12px; }
.contact-box-row span:last-child { color: #cc0000; font-weight: 600; }
.contact-box-note { margin-top: 8px; font-size: 11px; color: #444;
    text-align: center; border-top: 1px solid #2a2a2a; padding-top: 8px; }

/* ── APP SHELL ───────────────────────────────────── */
.app-shell { display: flex; height: 100vh; overflow: hidden; }
.sidebar { width: 240px; flex-shrink: 0; }
.main-content { flex: 1; overflow-y: auto; }
.content-wrap { padding: 0; }
</style>
