<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

<div class="nav-shell">

    <a href="/" class="nav-logo-link">
        <div class="nav-logo">
            <div class="logo-gear-wrap">
                <svg class="logo-gear" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <path fill="#cc0000" d="M43.3 5.6l-3.1 9.5c-2.3.6-4.5 1.5-6.5 2.7L24.4 13l-9 9 4.8 9.3c-1.2 2-2.1 4.2-2.7 6.5l-9.5 3.1v12.7l9.5 3.1c.6 2.3 1.5 4.5 2.7 6.5L15.4 73l9 9 9.3-4.8c2 1.2 4.2 2.1 6.5 2.7l3.1 9.5h12.7l3.1-9.5c2.3-.6 4.5-1.5 6.5-2.7l9.3 4.8 9-9-4.8-9.3c1.2-2 2.1-4.2 2.7-6.5l9.5-3.1V43.3l-9.5-3.1c-.6-2.3-1.5-4.5-2.7-6.5l4.8-9.3-9-9-9.3 4.8c-2-1.2-4.2-2.1-6.5-2.7l-3.1-9.5H43.3zM50 34c8.8 0 16 7.2 16 16s-7.2 16-16 16-16-7.2-16-16 7.2-16 16-16z" />
                    <circle fill="#1a1a1a" cx="50" cy="50" r="10" />
                </svg>
            </div>
            <div class="logo-text-wrap">
                <div class="logo-arabic">شیر ربانی آٹوز</div>
                <div class="logo-name">Sheer Rabbani</div>
                <div class="logo-autos">AUTOS</div>
            </div>
        </div>
    </a>

    <div class="nav-divider"></div>

    <nav class="nav-links">
        <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
            <span class="nav-dot"></span>
            <span class="nav-text">Home</span>
        </NavLink>
        <NavLink class="nav-item" href="products">
            <span class="nav-dot"></span>
            <span class="nav-text">Products</span>
        </NavLink>
        <NavLink class="nav-item" href="billing">
            <span class="nav-dot"></span>
            <span class="nav-text">Billing</span>
        </NavLink>
    </nav>

    <div class="nav-footer">

        <!-- Sync Button -->
        <button class="sync-btn @(_syncState)" @onclick="ManualSync" disabled="@(_syncState == "syncing")" title="@_syncTooltip">
            <span class="sync-icon-wrap">
                @if (_syncState == "syncing")
                {
                    <svg class="spin" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <path d="M21 12a9 9 0 1 1-6.219-8.56" />
                    </svg>
                }
                else if (_syncState == "success")
                {
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                }
                else if (_syncState == "error")
                {
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                }
                else
                {
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="1 4 1 10 7 10" />
                        <polyline points="23 20 23 14 17 14" />
                        <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15" />
                    </svg>
                }
            </span>
            <span class="sync-label">
                @if (_syncState == "syncing")
                {
                    <text>Syncing...</text>
                }
                else if (_syncState == "success")
                {

                    <text>Synced!</text>
                }
                else if (_syncState == "error")
                {

                    <text>Sync Failed</text>
                }
                else
                {

                    <text>Sync Now</text>
                }
            </span>
            @if (_lastSyncedAt.HasValue && _syncState == "idle")
            {
                <span class="sync-time">@_lastSyncedAt.Value.ToLocalTime().ToString("HH:mm")</span>
            }
        </button>

        <button class="close-app-btn" @onclick="@(() => showCloseWarning = true)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
            Close Application
        </button>
    </div>
</div>

<!-- Close Warning Modal -->
@if (showCloseWarning)
{
    <div class="modal-overlay" @onclick="@(() => showCloseWarning = false)">
        <div class="warn-modal" @onclick:stopPropagation="true">

            <div class="warn-icon-wrap">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#cc0000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
            </div>

            <div class="warn-title">Close Application?</div>
            <div class="warn-msg">Any unsaved data will be lost. Are you sure you want to exit?</div>

            <div class="warn-actions">
                <button class="btn-cancel" @onclick="@(() => showCloseWarning = false)">Cancel</button>
                <button class="btn-confirm" @onclick="ConfirmClose">Yes, Close</button>
            </div>
        </div>
    </div>
}

