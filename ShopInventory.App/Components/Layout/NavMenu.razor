<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

<div class="nav-shell">

    <a href="/" class="nav-logo-link">
        <div class="nav-logo">
            <div class="logo-gear-wrap">
                <svg class="logo-gear" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <path fill="#cc0000" d="M43.3 5.6l-3.1 9.5c-2.3.6-4.5 1.5-6.5 2.7L24.4 13l-9 9 4.8 9.3c-1.2 2-2.1 4.2-2.7 6.5l-9.5 3.1v12.7l9.5 3.1c.6 2.3 1.5 4.5 2.7 6.5L15.4 73l9 9 9.3-4.8c2 1.2 4.2 2.1 6.5 2.7l3.1 9.5h12.7l3.1-9.5c2.3-.6 4.5-1.5 6.5-2.7l9.3 4.8 9-9-4.8-9.3c1.2-2 2.1-4.2 2.7-6.5l9.5-3.1V43.3l-9.5-3.1c-.6-2.3-1.5-4.5-2.7-6.5l4.8-9.3-9-9-9.3 4.8c-2-1.2-4.2-2.1-6.5-2.7l-3.1-9.5H43.3zM50 34c8.8 0 16 7.2 16 16s-7.2 16-16 16-16-7.2-16-16 7.2-16 16-16z" />
                    <circle fill="#1a1a1a" cx="50" cy="50" r="10" />
                </svg>
            </div>
            <div class="logo-text-wrap">
                <div class="logo-arabic">شیر ربانی آٹوز</div>
                <div class="logo-name">Sheer Rabbani</div>
                <div class="logo-autos">AUTOS</div>
            </div>
        </div>
    </a>

    <div class="nav-divider"></div>

    <nav class="nav-links">
        <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
            <span class="nav-dot"></span>
            <span class="nav-text">Home</span>
        </NavLink>
        <NavLink class="nav-item" href="products">
            <span class="nav-dot"></span>
            <span class="nav-text">Products</span>
        </NavLink>
        <NavLink class="nav-item" href="billing">
            <span class="nav-dot"></span>
            <span class="nav-text">Billing</span>
        </NavLink>
    </nav>

    <div class="nav-footer">
        <button class="close-app-btn" @onclick="@(() => showCloseWarning = true)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
            Close Application
        </button>
    </div>
</div>

<!-- Close Warning Modal -->
@if (showCloseWarning)
{
    <div class="modal-overlay" @onclick="@(() => showCloseWarning = false)">
        <div class="warn-modal" @onclick:stopPropagation="true">

            <div class="warn-icon-wrap">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#cc0000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
            </div>

            <div class="warn-title">Close Application?</div>
            <div class="warn-msg">Any unsaved data will be lost. Are you sure you want to exit?</div>

            <div class="warn-actions">
                <button class="btn-cancel" @onclick="@(() => showCloseWarning = false)">Cancel</button>
                <button class="btn-confirm" @onclick="ConfirmClose">Yes, Close</button>
            </div>
        </div>
    </div>
}

@code {
    private bool showCloseWarning = false;

    private void ConfirmClose()
    {
        showCloseWarning = false;
        Microsoft.Maui.Controls.Application.Current?.Quit();
    }
}

<style>
    *, *::before, *::after {
        box-sizing: border-box;
    }

    .nav-shell {
        display: flex;
        flex-direction: column;
        height: 100%;
        color: #0f172a;
        font-family: 'DM Sans', sans-serif;
    }

    /* ── Logo ── */
    .nav-logo-link {
        text-decoration: none;
        display: block;
    }

        .nav-logo-link:hover .nav-logo {
            background: rgba(204,0,0,.05);
        }

    .nav-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 16px 10px;
        border-radius: 12px;
        transition: background .15s;
        cursor: pointer;
    }

    .logo-gear-wrap {
        width: 38px;
        height: 38px;
        flex-shrink: 0;
        background: #1a0a0a;
        border: 1px solid #cc0000;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 5px;
    }

    .logo-gear {
        width: 100%;
        height: 100%;
    }

    .logo-text-wrap {
        display: flex;
        flex-direction: column;
    }

    .logo-arabic {
        font-size: 9px;
        color: #666;
        letter-spacing: 1px;
        direction: rtl;
    }

    .logo-name {
        font-size: 13px;
        font-weight: 700;
        color: #111;
        line-height: 1.2;
    }

    .logo-autos {
        font-size: 9px;
        font-weight: 600;
        color: #cc0000;
        letter-spacing: 3px;
    }

    /* ── Divider ── */
    .nav-divider {
        height: 1px;
        background: #f0f0f0;
        margin: 4px 16px 8px;
    }

    /* ── Nav Links ── */
    .nav-links {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    ::deep a.nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 11px 14px;
        border-radius: 12px;
        text-decoration: none;
        color: #64748b;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.15s ease;
    }

        ::deep a.nav-item:hover {
            background: #f1f5f9;
            color: #0f172a;
        }

        ::deep a.nav-item.active {
            background: #0f172a;
            color: #fff;
        }

            ::deep a.nav-item.active .nav-dot {
                background: #38bdf8;
            }

    .nav-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #cbd5e1;
        flex-shrink: 0;
    }

    .nav-text {
        font-size: 14px;
    }

    /* ── Footer / Close Button ── */
    .nav-footer {
        margin-top: auto;
        padding: 12px 14px 18px;
    }

    .close-app-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        width: 100%;
        padding: 10px 14px;
        background: #fff0f0;
        border: 1px solid #fcd0d0;
        border-radius: 11px;
        cursor: pointer;
        color: #cc0000;
        font-size: 13px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        transition: background .15s, border-color .15s, transform .1s;
    }

        .close-app-btn:hover {
            background: #ffe4e4;
            border-color: #f5a0a0;
            transform: translateY(-1px);
        }

        .close-app-btn:active {
            transform: translateY(0);
        }

    /* ── Modal Overlay ── */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.55);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 1rem;
        animation: overlayIn .15s ease;
    }

    @@keyframes overlayIn {
        from {
            opacity: 0
        }

        to {
            opacity: 1
        }
    }

    /* ── Warning Modal ── */
    .warn-modal {
        background: #fff;
        border-radius: 18px;
        padding: 28px 24px 22px;
        width: 100%;
        max-width: 310px;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,.18);
        animation: slideUp .2s ease;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(16px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    .warn-icon-wrap {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: #fff0f0;
        border: 1px solid #fcd0d0;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

    .warn-title {
        font-size: 17px;
        font-weight: 700;
        color: #111;
        margin-bottom: 8px;
    }

    .warn-msg {
        font-size: 13px;
        color: #888;
        line-height: 1.55;
        margin-bottom: 22px;
    }

    .warn-actions {
        display: flex;
        gap: 10px;
    }

    .btn-cancel {
        flex: 1;
        padding: 10px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        color: #555;
        font-family: 'DM Sans', sans-serif;
        transition: background .15s;
    }

        .btn-cancel:hover {
            background: #e2e8f0;
        }

    .btn-confirm {
        flex: 1;
        padding: 10px;
        background: #cc0000;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        color: #fff;
        font-family: 'DM Sans', sans-serif;
        transition: background .15s;
    }

        .btn-confirm:hover {
            background: #a80000;
        }

    /* ── Responsive ── */
    @@media (max-width: 900px) {
        .nav-shell {
            height: auto;
        }

        .nav-footer {
            display: none;
        }
    }
</style>