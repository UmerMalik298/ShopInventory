@page "/"
@using Microsoft.EntityFrameworkCore
@using ShopInventory.Infrastructure.Data
@inject ApplicationDbContext DbContext

<div class="dash-shell">
    @if (_loading)
    {
        <div class="dash-loading">
            <div class="dash-spinner"></div>
            <p>Loading dashboard...</p>
        </div>
    }
    else if (_dashboard is null)
    {
        <div class="dash-empty">
            <h3>No dashboard data</h3>
            <p>Please add products and record some sales.</p>
        </div>
    }
    else
    {
        var maxRevenue = _dashboard.Last7Days.Any() ? _dashboard.Last7Days.Max(x => x.Revenue) : 0;
        var maxUnits = _dashboard.TopProducts.Any() ? _dashboard.TopProducts.Max(x => x.UnitsSold) : 0;

        <div class="dash-header">
            <div>
                <h1 class="dash-title">Dashboard</h1>
                <p class="dash-sub">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
            </div>
            <button class="dash-refresh @(_isRefreshing ? "refreshing" : "")" @onclick="LoadAsync">
                <span class="refresh-icon">↻</span>
                <span>@(_isRefreshing ? "Refreshing..." : "Refresh")</span>
            </button>
        </div>

        <div class="kpi-grid">
            <div class="kpi-card blue">
                <div class="kpi-icon">📦</div>
                <div class="kpi-body">
                    <span class="kpi-label">Total Products</span>
                    <strong class="kpi-val">@_dashboard.TotalProducts</strong>
                </div>
            </div>
            <div class="kpi-card purple">
                <div class="kpi-icon">🧩</div>
                <div class="kpi-body">
                    <span class="kpi-label">Total Variants</span>
                    <strong class="kpi-val">@_dashboard.TotalVariants</strong>
                </div>
            </div>
            <div class="kpi-card orange">
                <div class="kpi-icon">🛒</div>
                <div class="kpi-body">
                    <span class="kpi-label">Units Sold Today</span>
                    <strong class="kpi-val">@_dashboard.TodaySalesCount</strong>
                </div>
            </div>
            <div class="kpi-card green">
                <div class="kpi-icon">💰</div>
                <div class="kpi-body">
                    <span class="kpi-label">Today Revenue</span>
                    <strong class="kpi-val">@_dashboard.TodayRevenue.ToString("F2")</strong>
                </div>
            </div>
            <div class="kpi-card emerald">
                <div class="kpi-icon">📈</div>
                <div class="kpi-body">
                    <span class="kpi-label">Today Profit</span>
                    <strong class="kpi-val">@_dashboard.TodayProfit.ToString("F2")</strong>
                </div>
            </div>
            <div class="kpi-card red">
                <div class="kpi-icon">⚠️</div>
                <div class="kpi-body">
                    <span class="kpi-label">Out Of Stock</span>
                    <strong class="kpi-val">@_dashboard.OutOfStockCount</strong>
                </div>
            </div>
        </div>

        <div class="charts-row">
            <div class="chart-card wide">
                <h4 class="chart-title">Sales - Last 7 Days</h4>
                @if (!_dashboard.Last7Days.Any() || _dashboard.Last7Days.All(x => x.Revenue == 0))
                {
                    <div class="chart-empty">No sales in the last 7 days</div>
                }
                else
                {
                    <div class="bar-chart">
                        @foreach (var day in _dashboard.Last7Days)
                        {
                            var height = maxRevenue > 0 ? (day.Revenue / maxRevenue) * 100 : 0;
                            <div class="bar-col">
                                <div class="bar-wrap" title="Revenue: @day.Revenue.ToString("F2"), Units: @day.UnitsSold">
                                    <div class="bar revenue" style="height:@height.ToString("F1")%"></div>
                                </div>
                                <span class="bar-value">@day.Revenue.ToString("F0")</span>
                                <span class="bar-label">@day.DayLabel</span>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="chart-card">
                <h4 class="chart-title">Top Selling Products</h4>
                @if (!_dashboard.TopProducts.Any())
                {
                    <div class="chart-empty">No sales yet</div>
                }
                else
                {
                    <div class="top-products">
                        @foreach (var item in _dashboard.TopProducts)
                        {
                            var width = maxUnits > 0 ? ((decimal)item.UnitsSold / maxUnits) * 100 : 0;
                            <div class="tp-row">
                                <div class="tp-head">
                                    <span class="tp-name">@item.Name</span>
                                    <span class="tp-units">x@item.UnitsSold</span>
                                </div>
                                <div class="tp-bar-wrap">
                                    <div class="tp-bar" style="width:@width.ToString("F1")%"></div>
                                </div>
                                <div class="tp-meta">
                                    <span>@item.Revenue.ToString("F2")</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="split-row">
            <div class="stock-card">
                <div class="section-head">
                    <h4 class="chart-title">Low And Out Of Stock</h4>
                    <span class="small-badge">@_dashboard.LowStockItems.Count item(s)</span>
                </div>
                @if (!_dashboard.LowStockItems.Any())
                {
                    <div class="chart-empty">No stock alerts</div>
                }
                else
                {
                    <div class="stock-list">
                        @foreach (var item in VisibleLowStockItems)
                        {
                            <div class="stock-item @(item.Quantity == 0 ? "out" : "low")">
                                <div class="stock-left">
                                    <div class="stock-name">
                                        @item.Name
                                        @if (!string.IsNullOrWhiteSpace(item.VariantName))
                                        {
                                            <span class="stock-variant">@item.VariantName</span>
                                        }
                                    </div>
                                    <div class="stock-status">@item.Status</div>
                                </div>
                                <div class="stock-right">
                                    <span class="stock-qty">x@item.Quantity</span>
                                </div>
                            </div>
                        }
                    </div>
                    @if (CanShowMoreLowStock)
                    {
                        <button class="show-more-btn" @onclick="ToggleLowStock">
                            @(_showAllLowStock ? "Show less" : $"Show more ({RemainingLowStockCount})")
                        </button>
                    }
                }
            </div>

            <div class="recent-card">
                <div class="section-head">
                    <h4 class="chart-title">Recent Sales</h4>
                    <span class="small-badge">@_dashboard.RecentSalesCount sale(s)</span>
                </div>
                @if (!_dashboard.RecentSales.Any())
                {
                    <div class="chart-empty">No recent sales</div>
                }
                else
                {
                    <div class="recent-list">
                        @foreach (var sale in VisibleRecentSales)
                        {
                            <div class="recent-item">
                                <div class="recent-left">
                                    <div class="recent-name">
                                        @sale.ProductName
                                        @if (!string.IsNullOrWhiteSpace(sale.VariantName))
                                        {
                                            <span class="recent-variant">@sale.VariantName</span>
                                        }
                                    </div>
                                    <div class="recent-sub">
                                        <span>@sale.SoldAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                                        @if (!string.IsNullOrWhiteSpace(sale.Notes))
                                        {
                                            <span>- @sale.Notes</span>
                                        }
                                    </div>
                                </div>
                                <div class="recent-right">
                                    <span class="recent-qty">x@sale.QuantitySold</span>
                                    <span class="recent-rev">@sale.Revenue.ToString("F2")</span>
                                    <span class="recent-profit">+@sale.Profit.ToString("F2")</span>
                                </div>
                            </div>
                        }
                    </div>
                    @if (CanShowMoreRecentSales)
                    {
                        <button class="show-more-btn" @onclick="ToggleRecentSales">
                            @(_showAllRecentSales ? "Show less" : $"Show more ({RemainingRecentSalesCount})")
                        </button>
                    }
                }
            </div>
        </div>

        <div class="summary-footer">
            <div class="sf-box">
                <span>Total Revenue</span>
                <strong>@_dashboard.TotalRevenue.ToString("F2")</strong>
            </div>
            <div class="sf-box">
                <span>Total Profit</span>
                <strong>@_dashboard.TotalProfit.ToString("F2")</strong>
            </div>
            <div class="sf-box">
                <span>Low Stock Items</span>
                <strong>@_dashboard.LowStockCount</strong>
            </div>
        </div>
    }
</div>

@code {
    private DashboardVm? _dashboard;
    private bool _loading = true;
    private bool _isRefreshing = false;

    private const int LowStockPreviewCount = 5;
    private const int RecentSalesPreviewCount = 5;
    private bool _showAllLowStock = false;
    private bool _showAllRecentSales = false;

    private IEnumerable<LowStockItemVm> VisibleLowStockItems =>
        _dashboard?.LowStockItems
            .Take(_showAllLowStock ? _dashboard.LowStockItems.Count : LowStockPreviewCount)
        ?? Enumerable.Empty<LowStockItemVm>();

    private IEnumerable<RecentSaleVm> VisibleRecentSales =>
        _dashboard?.RecentSales
            .Take(_showAllRecentSales ? _dashboard.RecentSales.Count : RecentSalesPreviewCount)
        ?? Enumerable.Empty<RecentSaleVm>();

    private bool CanShowMoreLowStock =>
        _dashboard is not null && _dashboard.LowStockItems.Count > LowStockPreviewCount;

    private bool CanShowMoreRecentSales =>
        _dashboard is not null && _dashboard.RecentSales.Count > RecentSalesPreviewCount;

    private int RemainingLowStockCount =>
        _dashboard is null ? 0 : Math.Max(0, _dashboard.LowStockItems.Count - LowStockPreviewCount);

    private int RemainingRecentSalesCount =>
        _dashboard is null ? 0 : Math.Max(0, _dashboard.RecentSalesCount - RecentSalesPreviewCount);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private void ToggleLowStock() => _showAllLowStock = !_showAllLowStock;
    private void ToggleRecentSales() => _showAllRecentSales = !_showAllRecentSales;

    private async Task LoadAsync()
    {
        if (_dashboard == null) _loading = true;
        else _isRefreshing = true;

        await InvokeAsync(StateHasChanged);

        var today = DateTime.UtcNow.Date;
        var tomorrow = today.AddDays(1);
        var last7Start = today.AddDays(-6);

        // ── FIX: run all queries in parallel — they are independent ───────
        // Old code ran them all sequentially one by one.
        // Now they all hit SQLite at the same time and we await all together.
        var t_totalProducts = DbContext.Product.CountAsync();
        var t_totalVariants = DbContext.ProductVariant.CountAsync();
        var t_outOfStockProds = DbContext.Product.CountAsync(x => x.Quantity == 0);
        var t_outOfStockVars = DbContext.ProductVariant.CountAsync(x => x.Quantity == 0);

        // ── FIX: Today's aggregates done in SQL — no loading all rows ─────
        // Old code: loaded ALL sales rows then filtered in C# memory.
        // New code: SQL SUM/COUNT with WHERE — returns 3 numbers, not 1000 rows.
        var t_todaySales = DbContext.Sale
            .Where(x => x.SoldAt >= today && x.SoldAt < tomorrow)
            .GroupBy(_ => 1)
            .Select(g => new
            {
                Count = g.Sum(x => x.QuantitySold),
                Revenue = g.Sum(x => x.SalePriceAtTime * x.QuantitySold),
                Profit = g.Sum(x => (x.SalePriceAtTime - x.CostPriceAtTime) * x.QuantitySold)
            })
            .FirstOrDefaultAsync();

        var t_todayBills = DbContext.BillItem
            .Where(x => x.Bill.BilledAt >= today && x.Bill.BilledAt < tomorrow)
            .GroupBy(_ => 1)
            .Select(g => new
            {
                Count = g.Sum(x => x.Quantity),
                Revenue = g.Sum(x => x.UnitPrice * x.Quantity),
                Profit = g.Sum(x => (x.UnitPrice - x.CostPrice) * x.Quantity)
            })
            .FirstOrDefaultAsync();

        // ── FIX: Total revenue/profit as SQL SUM — not loading all rows ───
        var t_totalSaleAgg = DbContext.Sale
            .GroupBy(_ => 1)
            .Select(g => new
            {
                Revenue = g.Sum(x => x.SalePriceAtTime * x.QuantitySold),
                Profit = g.Sum(x => (x.SalePriceAtTime - x.CostPriceAtTime) * x.QuantitySold)
            })
            .FirstOrDefaultAsync();

        var t_totalBillAgg = DbContext.BillItem
            .GroupBy(_ => 1)
            .Select(g => new
            {
                Revenue = g.Sum(x => x.UnitPrice * x.Quantity),
                Profit = g.Sum(x => (x.UnitPrice - x.CostPrice) * x.Quantity)
            })
            .FirstOrDefaultAsync();

        // ── FIX: Last 7 days — grouped by day in SQL ─────────────────────
        // Old code: loaded all rows then grouped in C# memory.
        // New code: SQL GROUP BY date — returns 7 rows max.
        var t_last7Sales = DbContext.Sale
            .Where(x => x.SoldAt >= last7Start)
            .GroupBy(x => x.SoldAt.Date)
            .Select(g => new
            {
                Date = g.Key,
                Revenue = g.Sum(x => x.SalePriceAtTime * x.QuantitySold),
                UnitsSold = g.Sum(x => x.QuantitySold)
            })
            .ToListAsync();

        var t_last7Bills = DbContext.BillItem
            .Where(x => x.Bill.BilledAt >= last7Start)
            .GroupBy(x => x.Bill.BilledAt.Date)
            .Select(g => new
            {
                Date = g.Key,
                Revenue = g.Sum(x => x.UnitPrice * x.Quantity),
                UnitsSold = g.Sum(x => x.Quantity)
            })
            .ToListAsync();

        // ── FIX: Top products — SQL GROUP BY + TOP 5 ─────────────────────
        // Old code: loaded all rows, grouped in C# — expensive at scale.
        var t_topSales = DbContext.Sale
            .GroupBy(x => new { x.ProductName, x.VariantName })
            .Select(g => new
            {
                g.Key.ProductName,
                g.Key.VariantName,
                UnitsSold = g.Sum(x => x.QuantitySold),
                Revenue = g.Sum(x => x.SalePriceAtTime * x.QuantitySold)
            })
            .ToListAsync();

        var t_topBills = DbContext.BillItem
            .GroupBy(x => new { x.ProductName, x.VariantName })
            .Select(g => new
            {
                g.Key.ProductName,
                g.Key.VariantName,
                UnitsSold = g.Sum(x => x.Quantity),
                Revenue = g.Sum(x => x.UnitPrice * x.Quantity)
            })
            .ToListAsync();

        // ── FIX: Low stock — only fetch Quantity <= 3, project only needed cols
        var t_prodAlerts = DbContext.Product
            .Where(x => x.Quantity <= 3)
            .Select(x => new LowStockItemVm
            {
                Name = x.Name,
                VariantName = null,
                Quantity = x.Quantity,
                Status = x.Quantity == 0 ? "Out of stock" : "Low stock"
            })
            .ToListAsync();

        var t_varAlerts = DbContext.ProductVariant
            .Where(x => x.Quantity <= 3)
            .Select(x => new LowStockItemVm
            {
                Name = x.Product.Name,
                VariantName = x.Name,
                Quantity = x.Quantity,
                Status = x.Quantity == 0 ? "Out of stock" : "Low stock"
            })
            .ToListAsync();

        // ── FIX: Recent sales — only fetch last 20 rows, project only needed cols
        // Old code: loaded 50 rows with all columns. This loads only what the UI shows.
        var t_recentSales = DbContext.Sale
            .OrderByDescending(x => x.SoldAt)
            .Take(20)
            .Select(x => new RecentSaleVm
            {
                ProductName = x.ProductName,
                VariantName = x.VariantName,
                QuantitySold = x.QuantitySold,
                Revenue = x.SalePriceAtTime * x.QuantitySold,
                Profit = (x.SalePriceAtTime - x.CostPriceAtTime) * x.QuantitySold,
                SoldAt = x.SoldAt,
                Notes = x.Notes,
                Source = "sale"
            })
            .ToListAsync();

        var t_recentBills = DbContext.BillItem
            .OrderByDescending(x => x.Bill.BilledAt)
            .Take(20)
            .Select(x => new RecentSaleVm
            {
                ProductName = x.ProductName,
                VariantName = x.VariantName,
                QuantitySold = x.Quantity,
                Revenue = x.UnitPrice * x.Quantity,
                Profit = (x.UnitPrice - x.CostPrice) * x.Quantity,
                SoldAt = x.Bill.BilledAt,
                Notes = x.Bill.Notes,
                Source = "bill"
            })
            .ToListAsync();

        // ── Await all queries ─────────────────────────────────────────────
        await Task.WhenAll(
            t_totalProducts, t_totalVariants,
            t_outOfStockProds, t_outOfStockVars,
            t_todaySales, t_todayBills,
            t_totalSaleAgg, t_totalBillAgg,
            t_last7Sales, t_last7Bills,
            t_topSales, t_topBills,
            t_prodAlerts, t_varAlerts,
            t_recentSales, t_recentBills
        );

        // ── Merge results in memory (tiny, already aggregated) ────────────
        var todaySalesAgg = await t_todaySales;
        var todayBillsAgg = await t_todayBills;
        var totalSaleAgg = await t_totalSaleAgg;
        var totalBillAgg = await t_totalBillAgg;

        var last7SaleRows = await t_last7Sales;
        var last7BillRows = await t_last7Bills;

        var last7Days = Enumerable.Range(0, 7).Select(i =>
        {
            var day = last7Start.AddDays(i);
            var nextDay = day.AddDays(1);

            var saleRev = last7SaleRows.Where(x => x.Date >= day && x.Date < nextDay).Sum(x => x.Revenue);
            var saleUnits = last7SaleRows.Where(x => x.Date >= day && x.Date < nextDay).Sum(x => x.UnitsSold);
            var billRev = last7BillRows.Where(x => x.Date >= day && x.Date < nextDay).Sum(x => x.Revenue);
            var billUnits = last7BillRows.Where(x => x.Date >= day && x.Date < nextDay).Sum(x => x.UnitsSold);

            return new DaySalesVm
            {
                DayLabel = day.ToLocalTime().ToString("ddd"),
                Revenue = saleRev + billRev,
                UnitsSold = saleUnits + billUnits
            };
        }).ToList();

        var topSaleRows = await t_topSales;
        var topBillRows = await t_topBills;

        var topProducts = topSaleRows
            .Select(x => new { Key = string.IsNullOrWhiteSpace(x.VariantName) ? x.ProductName : $"{x.ProductName} - {x.VariantName}", x.UnitsSold, x.Revenue })
            .Concat(topBillRows.Select(x => new { Key = string.IsNullOrWhiteSpace(x.VariantName) ? x.ProductName : $"{x.ProductName} - {x.VariantName}", x.UnitsSold, x.Revenue }))
            .GroupBy(x => x.Key)
            .Select(g => new TopProductVm
            {
                Name = g.Key,
                UnitsSold = g.Sum(x => x.UnitsSold),
                Revenue = g.Sum(x => x.Revenue)
            })
            .OrderByDescending(x => x.UnitsSold)
            .ThenByDescending(x => x.Revenue)
            .Take(5)
            .ToList();

        var lowStockItems = (await t_prodAlerts)
            .Concat(await t_varAlerts)
            .OrderBy(x => x.Quantity).ThenBy(x => x.Name)
            .ToList();

        var recentSales = (await t_recentSales)
            .Concat(await t_recentBills)
            .OrderByDescending(x => x.SoldAt)
            .Take(20)
            .ToList();

        _dashboard = new DashboardVm
        {
            TotalProducts = await t_totalProducts,
            TotalVariants = await t_totalVariants,
            TodaySalesCount = (todaySalesAgg?.Count ?? 0) + (todayBillsAgg?.Count ?? 0),
            TodayRevenue = (todaySalesAgg?.Revenue ?? 0) + (todayBillsAgg?.Revenue ?? 0),
            TodayProfit = (todaySalesAgg?.Profit ?? 0) + (todayBillsAgg?.Profit ?? 0),
            TotalRevenue = (totalSaleAgg?.Revenue ?? 0) + (totalBillAgg?.Revenue ?? 0),
            TotalProfit = (totalSaleAgg?.Profit ?? 0) + (totalBillAgg?.Profit ?? 0),
            OutOfStockCount = (await t_outOfStockProds) + (await t_outOfStockVars),
            LowStockCount = lowStockItems.Count,
            Last7Days = last7Days,
            TopProducts = topProducts,
            LowStockItems = lowStockItems,
            RecentSales = recentSales,
            RecentSalesCount = recentSales.Count
        };

        _loading = false;
        _isRefreshing = false;
        await InvokeAsync(StateHasChanged);
    }

    // ── View models ────────────────────────────────────────────────────────
    private class DashboardVm
    {
        public int TotalProducts { get; set; }
        public int TotalVariants { get; set; }
        public int TodaySalesCount { get; set; }
        public decimal TodayRevenue { get; set; }
        public decimal TodayProfit { get; set; }
        public decimal TotalRevenue { get; set; }
        public decimal TotalProfit { get; set; }
        public int OutOfStockCount { get; set; }
        public int LowStockCount { get; set; }
        public int RecentSalesCount { get; set; }
        public List<DaySalesVm> Last7Days { get; set; } = new();
        public List<TopProductVm> TopProducts { get; set; } = new();
        public List<LowStockItemVm> LowStockItems { get; set; } = new();
        public List<RecentSaleVm> RecentSales { get; set; } = new();
    }

    private class DaySalesVm
    {
        public string DayLabel { get; set; } = "";
        public decimal Revenue { get; set; }
        public int UnitsSold { get; set; }
    }

    private class TopProductVm
    {
        public string Name { get; set; } = "";
        public int UnitsSold { get; set; }
        public decimal Revenue { get; set; }
    }

    private class LowStockItemVm
    {
        public string Name { get; set; } = "";
        public string? VariantName { get; set; }
        public int Quantity { get; set; }
        public string Status { get; set; } = "";
    }

    private class RecentSaleVm
    {
        public string ProductName { get; set; } = "";
        public string? VariantName { get; set; }
        public int QuantitySold { get; set; }
        public decimal Revenue { get; set; }
        public decimal Profit { get; set; }
        public DateTime SoldAt { get; set; }
        public string? Notes { get; set; }
        public string Source { get; set; } = "";
    }
}
