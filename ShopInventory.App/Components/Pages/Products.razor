@page "/products"
@using ShopInventory.App.Components.Products

<h3 class="page-title">Products</h3>

<div class="products-shell">
    <div class="tabs-header">
        <button class="tab-btn @(activeTab == "list" ? "active" : "")" @onclick='() => SetTab("list")'>
            All Products
        </button>
        <button class="tab-btn @(activeTab == "add" ? "active" : "")" @onclick='() => SetTab("add")'>
            Add Product
        </button>
        <button class="tab-btn @(activeTab == "manage" ? "active" : "")" @onclick='() => SetTab("manage")'>
            Manage Stock
        </button>
    </div>

    <div style="display:@(activeTab == "list" ? "block" : "none")">
        <AllProducts @ref="_allProducts" />
    </div>

    @if (activeTab == "add")
    {
        <AddProduct OnProductAdded="@OnProductAdded" />
    }

    @if (activeTab == "manage")
    {
        <ManageStock />
    }
</div>

@code {
    private string activeTab = "list";
    private AllProducts? _allProducts;

    private void SetTab(string tab)
    {
        activeTab = tab;
    }

    private async Task OnProductAdded()
    {
        activeTab = "list";
        StateHasChanged();
        await Task.Delay(150);
        if (_allProducts != null)
            await _allProducts.LoadProductsAsync();
    }
}