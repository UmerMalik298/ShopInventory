@page "/products"
@using ShopInventory.Application.DTOs
@using ShopInventory.Application.Interfaces
@inject IProductService ProductService

<h3 class="page-title">Products</h3>

<div class="products-shell">
    <div class="tabs-header">
        <button class="tab-btn @(activeTab == "list" ? "active" : "")" @onclick='() => SetTab("list")'>
            All Products
        </button>
        <button class="tab-btn @(activeTab == "add" ? "active" : "")" @onclick='() => SetTab("add")'>
            Add Product
        </button>
        <button class="tab-btn @(activeTab == "manage" ? "active" : "")" @onclick='() => SetTab("manage")'>
            Manage Stock
        </button>
    </div>

    @if (activeTab == "list")
    {
        <ProductListSection Products="_products"
                            OnSearch="SearchProductsAsync"
                            OnReset="LoadProductsAsync" />
    }

    @if (activeTab == "add")
    {
        <AddProductSection OnAddProduct="AddProductAsync" />
    }

    @if (activeTab == "manage")
    {
        <ManageStockSection Products="_products"
                            OnIncreaseQuantity="IncreaseQuantityAsync"
                            OnDecreaseQuantity="DecreaseQuantityAsync"
                            OnDeleteProduct="DeleteProductAsync" />
    }
</div>

@code {
    private string activeTab = "list";
    private List<ProductDto> _products = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private void SetTab(string tab) => activeTab = tab;

    private async Task LoadProductsAsync()
    {
        _products = await ProductService.GetAllAsync();
    }

    private async Task SearchProductsAsync(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            await LoadProductsAsync();
            return;
        }

        _products = await ProductService.SearchAsync(text);
    }

    private async Task AddProductAsync(CreateProductDto model)
    {
        await ProductService.AddAsync(model);
        await LoadProductsAsync();
        activeTab = "list";
    }

    private async Task IncreaseQuantityAsync(Guid id)
    {
        await ProductService.UpdateQuantityAsync(id, 1);
        await LoadProductsAsync();
    }

    private async Task DecreaseQuantityAsync(Guid id)
    {
        await ProductService.UpdateQuantityAsync(id, -1);
        await LoadProductsAsync();
    }

    private async Task DeleteProductAsync(Guid id)
    {
        await ProductService.DeleteAsync(id);
        await LoadProductsAsync();
    }
}